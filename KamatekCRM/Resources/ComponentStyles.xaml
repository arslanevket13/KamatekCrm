<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:km="clr-namespace:KamatekCrm.Components">

    <!-- ═══════════════════════════════════════════════════════════════════
         KAMATEK CRM — PREMIUM COMPONENT STYLES
         ControlTemplates for all Km* components.
    ═══════════════════════════════════════════════════════════════════ -->

    <!-- ─────────── KmStatusBadge ─────────── -->
    <Style TargetType="{x:Type km:KmStatusBadge}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type km:KmStatusBadge}">
                    <Border Background="{TemplateBinding BadgeBackground}"
                            CornerRadius="12"
                            Padding="10,4,12,4"
                            SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Pulsing dot -->
                            <Ellipse x:Name="StatusDot"
                                     Width="7" Height="7"
                                     Fill="{TemplateBinding DotColor}"
                                     Margin="0,0,6,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation 
                                                    Storyboard.TargetName="StatusDot"
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="1" To="0.4" Duration="0:0:1.5"
                                                    AutoReverse="True">
                                                    <DoubleAnimation.EasingFunction>
                                                        <SineEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <!-- Text label -->
                            <TextBlock Text="{TemplateBinding Text}"
                                       Foreground="{TemplateBinding BadgeForeground}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────── KmKpiCard ─────────── -->
    <Style TargetType="{x:Type km:KmKpiCard}">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type km:KmKpiCard}">
                    <Border x:Name="CardRoot"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="14"
                            Padding="20,18"
                            MinWidth="{DynamicResource KpiCardMinWidth}"
                            MinHeight="{DynamicResource KpiCardHeight}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.12"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Top: Title + Icon -->
                            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                <!-- Accent strip -->
                                <Border DockPanel.Dock="Right"
                                        Background="{TemplateBinding AccentBrush}"
                                        CornerRadius="8"
                                        Width="40" Height="40"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{TemplateBinding Icon}"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White"/>
                                </Border>
                                <TextBlock Text="{TemplateBinding Title}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           VerticalAlignment="Top"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>

                            <!-- Center: Value with prefix/suffix -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" 
                                        VerticalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock Text="{TemplateBinding Prefix}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="22"
                                           FontWeight="Light"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,4,2"/>
                                <TextBlock Text="{TemplateBinding DisplayValue}"
                                           Foreground="{DynamicResource TextHeadingBrush}"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           VerticalAlignment="Bottom"/>
                                <TextBlock Text="{TemplateBinding Suffix}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="14"
                                           FontWeight="Normal"
                                           VerticalAlignment="Bottom"
                                           Margin="4,0,0,4"/>
                            </StackPanel>

                            <!-- Bottom: Trend + Subtitle -->
                            <DockPanel Grid.Row="2" Margin="0,6,0,0">
                                <!-- Trend indicator -->
                                <Border DockPanel.Dock="Left"
                                        Visibility="{TemplateBinding TrendVisibility}"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{TemplateBinding TrendArrow}"
                                                   Foreground="{TemplateBinding TrendBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,3,0"/>
                                        <TextBlock Text="{TemplateBinding TrendText}"
                                                   Foreground="{TemplateBinding TrendBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <!-- Subtitle -->
                                <TextBlock Text="{TemplateBinding Subtitle}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Grid>
                    </Border>

                    <!-- Hover animation -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CardRoot"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.02" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="CardRoot"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.02" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CardRoot"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="CardRoot"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────── KmEmptyState ─────────── -->
    <Style TargetType="{x:Type km:KmEmptyState}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type km:KmEmptyState}">
                    <Border Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center" MaxWidth="360">
                            <!-- Icon circle -->
                            <Border Background="{DynamicResource StatusNeutralBg}"
                                    CornerRadius="40"
                                    Width="80" Height="80"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,20">
                                <TextBlock Text="{TemplateBinding Icon}"
                                           FontSize="36"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </Border>
                            <!-- Title -->
                            <TextBlock Text="{TemplateBinding Title}"
                                       Foreground="{DynamicResource TextHeadingBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <!-- Message -->
                            <TextBlock Text="{TemplateBinding Message}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="13"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,20"/>
                            <!-- Action button -->
                            <Button x:Name="PART_ActionButton"
                                    Content="{TemplateBinding ActionText}"
                                    Command="{TemplateBinding ActionCommand}"
                                    Style="{DynamicResource FluentButton}"
                                    HorizontalAlignment="Center"
                                    Padding="24,10"
                                    Visibility="{TemplateBinding ActionVisibility}"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────── KmSearchBox ─────────── -->
    <Style TargetType="{x:Type km:KmSearchBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type km:KmSearchBox}">
                    <Border x:Name="SearchBorder"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="10"
                            Padding="12,0"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            Height="40"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search icon -->
                            <Path Grid.Column="0"
                                  Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                                  Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"/>

                            <!-- Input -->
                            <TextBox x:Name="PART_SearchInput"
                                     Grid.Column="1"
                                     Text="{Binding SearchText, RelativeSource={RelativeSource TemplatedParent}, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TextBodyBrush}"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     CaretBrush="{DynamicResource PrimaryBrush}"/>

                            <!-- Placeholder -->
                            <TextBlock Grid.Column="1"
                                       Text="{TemplateBinding Placeholder}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Opacity="0.6">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SearchText, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Clear button -->
                            <Button x:Name="PART_ClearButton"
                                    Grid.Column="2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="4"
                                    VerticalAlignment="Center"
                                    Command="{Binding ClearCommand, RelativeSource={RelativeSource TemplatedParent}}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasText, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                      Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                      Width="12" Height="12"
                                      Stretch="Uniform"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger SourceName="PART_SearchInput" Property="IsFocused" Value="True">
                            <Setter TargetName="SearchBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="SearchBorder" Property="BorderThickness" Value="1.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────── KmBreadcrumb ─────────── -->
    <Style TargetType="{x:Type km:KmBreadcrumb}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type km:KmBreadcrumb}">
                    <ItemsControl ItemsSource="{TemplateBinding Items}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="›"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="14"
                                               Margin="6,0"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource PreviousData}}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding}"
                                               Foreground="{DynamicResource TextBodyBrush}"
                                               FontSize="13"
                                               FontWeight="Normal"
                                               VerticalAlignment="Center"
                                               Cursor="Hand"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────── KmTimeline ─────────── -->
    <Style TargetType="{x:Type km:KmTimeline}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type km:KmTimeline}">
                    <ItemsControl ItemsSource="{TemplateBinding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type km:TimelineItem}">
                                <Grid Margin="0,0,0,4" MinHeight="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Vertical line + dot -->
                                    <Canvas Grid.Column="0" Width="24">
                                        <!-- Connector line -->
                                        <Line X1="12" Y1="0" X2="12" Y2="60"
                                              Stroke="{DynamicResource BorderSubtleBrush}"
                                              StrokeThickness="1.5"/>
                                        <!-- Dot -->
                                        <Ellipse Width="10" Height="10"
                                                 Canvas.Left="7" Canvas.Top="6"
                                                 Fill="{Binding DotBrush}"/>
                                    </Canvas>

                                    <!-- Content -->
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding TimeAgo}"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{DynamicResource TextHeadingBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────── KmFilterPanel ─────────── -->
    <Style TargetType="{x:Type km:KmFilterPanel}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type km:KmFilterPanel}">
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="10"
                            Padding="16,12"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderSubtleBrush}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Filter icon -->
                            <Path Data="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z"
                                  Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"/>

                            <!-- Date From -->
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Başlangıç" FontSize="10"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,2"/>
                                <DatePicker SelectedDate="{Binding DateFrom, RelativeSource={RelativeSource TemplatedParent}}"
                                            Width="130" FontSize="12"/>
                            </StackPanel>

                            <!-- Date To -->
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Bitiş" FontSize="10"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,2"/>
                                <DatePicker SelectedDate="{Binding DateTo, RelativeSource={RelativeSource TemplatedParent}}"
                                            Width="130" FontSize="12"/>
                            </StackPanel>

                            <!-- Status dropdown -->
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Durum" FontSize="10"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,2"/>
                                <ComboBox ItemsSource="{TemplateBinding StatusItems}"
                                          SelectedItem="{Binding SelectedStatus, RelativeSource={RelativeSource TemplatedParent}}"
                                          Width="120" FontSize="12"/>
                            </StackPanel>

                            <!-- Category dropdown -->
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Kategori" FontSize="10"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,2"/>
                                <ComboBox ItemsSource="{TemplateBinding CategoryItems}"
                                          SelectedItem="{Binding SelectedCategory, RelativeSource={RelativeSource TemplatedParent}}"
                                          Width="120" FontSize="12"/>
                            </StackPanel>

                            <!-- Apply button -->
                            <Button Content="Filtrele"
                                    Command="{TemplateBinding ApplyCommand}"
                                    Style="{DynamicResource FluentButton}"
                                    Padding="16,6"
                                    FontSize="12"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,8,0"/>

                            <!-- Clear all -->
                            <Button Content="Temizle"
                                    Command="{TemplateBinding ClearAllCommand}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    BorderThickness="0"
                                    FontSize="12"
                                    Cursor="Hand"
                                    VerticalAlignment="Bottom"
                                    Padding="8,6"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>


