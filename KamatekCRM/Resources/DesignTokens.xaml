<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════════════
         KAMATEK CRM — THE PHYSICS ENGINE (DESIGN TOKENS v3.0)
         Semantic design system: Layout, typography scales, animations, forms.
         STRICT RULE: NO COLORS OR BRUSHES ALLOWED IN THIS FILE.
    ═══════════════════════════════════════════════════════════════════ -->

    <!-- ─────────── SPACING SCALE ─────────── -->
    <sys:Double x:Key="Space4">4</sys:Double>
    <sys:Double x:Key="Space8">8</sys:Double>
    <sys:Double x:Key="Space12">12</sys:Double>
    <sys:Double x:Key="Space16">16</sys:Double>
    <sys:Double x:Key="Space24">24</sys:Double>
    <sys:Double x:Key="Space32">32</sys:Double>
    <sys:Double x:Key="Space48">48</sys:Double>
    <sys:Double x:Key="Space64">64</sys:Double>

    <!-- Legacy Mappings -->
    <sys:Double x:Key="SpaceXXS">4</sys:Double>
    <sys:Double x:Key="SpaceXS">8</sys:Double>
    <sys:Double x:Key="SpaceSM">12</sys:Double>
    <sys:Double x:Key="SpaceMD">16</sys:Double>
    <sys:Double x:Key="SpaceLG">24</sys:Double>
    <sys:Double x:Key="SpaceXL">32</sys:Double>
    <sys:Double x:Key="SpaceXXL">48</sys:Double>
    <sys:Double x:Key="Space3XL">64</sys:Double>

    <!-- ─────────── GEOMETRY (CORNER RADIUS) ─────────── -->
    <CornerRadius x:Key="RadiusSmall">6</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">12</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">16</CornerRadius>
    <CornerRadius x:Key="RadiusXL">24</CornerRadius>

    <!-- ─────────── ICON SIZES ─────────── -->
    <sys:Double x:Key="IconXS">12</sys:Double>
    <sys:Double x:Key="IconSM">16</sys:Double>
    <sys:Double x:Key="IconMD">20</sys:Double>
    <sys:Double x:Key="IconLG">24</sys:Double>
    <sys:Double x:Key="IconXL">32</sys:Double>
    <sys:Double x:Key="IconXXL">48</sys:Double>

    <!-- ─────────── WORLD-CLASS ELEVATION (FLOATING SHADOW PHYSICS) ─────────── -->
    <DropShadowEffect x:Key="Elevation0" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
    
    <!-- Elevation 1: Buttons, Inputs, very subtle lift -->
    <DropShadowEffect x:Key="Elevation1" BlurRadius="6" ShadowDepth="2" Direction="270" Color="#0F172A" Opacity="0.04"/>
    
    <!-- Elevation 2: Main Cards, Hover States -->
    <DropShadowEffect x:Key="Elevation2" BlurRadius="12" ShadowDepth="4" Direction="270" Color="#0F172A" Opacity="0.06"/>
    
    <!-- Elevation 3: Modals, Popovers, Dropdowns -->
    <DropShadowEffect x:Key="Elevation3" BlurRadius="24" ShadowDepth="8" Direction="270" Color="#0F172A" Opacity="0.08"/>
    
    <!-- Elevation 4: Dialogs, High-altitude float -->
    <DropShadowEffect x:Key="Elevation4" BlurRadius="32" ShadowDepth="12" Direction="270" Color="#0F172A" Opacity="0.10"/>
    
    <!-- Elevation 5: Maximum focus, Full-screen overlays -->
    <DropShadowEffect x:Key="Elevation5" BlurRadius="48" ShadowDepth="16" Direction="270" Color="#0F172A" Opacity="0.12"/>

    <!-- Legacy shadow mappings to prevent compilation errors -->
    <DropShadowEffect x:Key="DropShadow" BlurRadius="12" ShadowDepth="4" Direction="270" Color="#0F172A" Opacity="0.06"/>
    <DropShadowEffect x:Key="DropShadowLight" BlurRadius="6" ShadowDepth="2" Direction="270" Color="#0F172A" Opacity="0.04"/>
    <DropShadowEffect x:Key="DropShadowHeavy" BlurRadius="24" ShadowDepth="8" Direction="270" Color="#0F172A" Opacity="0.08"/>

    <!-- ─────────── DURATION & EASING (Animation Tokens) ─────────── -->
    <Duration x:Key="DurationFast">0:0:0.15</Duration>
    <Duration x:Key="DurationNormal">0:0:0.25</Duration>
    <Duration x:Key="DurationSlow">0:0:0.4</Duration>
    <Duration x:Key="DurationVerySlow">0:0:0.6</Duration>

    <QuadraticEase x:Key="EaseOut" EasingMode="EaseOut"/>
    <CubicEase x:Key="EaseInOut" EasingMode="EaseInOut"/>
    <BackEase x:Key="EaseOutBack" EasingMode="EaseOut" Amplitude="0.3"/>
    <ElasticEase x:Key="EaseOutElastic" EasingMode="EaseOut" Oscillations="1" Springiness="5"/>

    <!-- ─────────── COMPONENT-SPECIFIC DIMENSIONS ─────────── -->
    <sys:Double x:Key="DataGridRowHeight">48</sys:Double>
    <sys:Double x:Key="DataGridHeaderHeight">44</sys:Double>
    <sys:Double x:Key="SidebarWidth">260</sys:Double>
    <sys:Double x:Key="SidebarCollapsedWidth">68</sys:Double>
    <sys:Double x:Key="KpiCardMinWidth">240</sys:Double>
    <sys:Double x:Key="KpiCardHeight">120</sys:Double>
    
    <!-- Avatar Defaults -->
    <sys:Double x:Key="AvatarSizeSM">28</sys:Double>
    <sys:Double x:Key="AvatarSizeMD">36</sys:Double>
    <sys:Double x:Key="AvatarSizeLG">48</sys:Double>
    <sys:Double x:Key="AvatarSizeXL">64</sys:Double>

</ResourceDictionary>
