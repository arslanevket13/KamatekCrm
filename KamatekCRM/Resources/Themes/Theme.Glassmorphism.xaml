<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════
         KAMATEK CRM — THE MASTERPIECE PALETTE (GLASSMORPHISM THEME)
         Translucent aesthetics with acrylic blur and subtle white borders.
    ═══════════════════════════════════════════════════════════════════ -->

    <!-- ─────────── PAGE & BACKGROUNDS (The Canvas) ─────────── -->
    <!-- Background is an atmospheric midnight gradient -->
    <LinearGradientBrush x:Key="SurfacePageBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#171120" Offset="0"/>
        <GradientStop Color="#091428" Offset="0.5"/>
        <GradientStop Color="#111B3D" Offset="1"/>
    </LinearGradientBrush>
    
    <Color x:Key="SurfacePageColor">#091428</Color>
    <Color x:Key="ThemeBackgroundColor">#091428</Color>
    <SolidColorBrush x:Key="ThemeBackground" Color="#091428"/>
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#091428"/>

    <!-- ─────────── SURFACES & CARDS (Glass Effect - 10% Opacity) ─────────── -->
    <Color x:Key="SurfaceCardColor">#FFFFFF</Color>
    <Color x:Key="ThemeSurfaceColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="ThemeSurface" Color="#FFFFFF" Opacity="0.08"/>
    <SolidColorBrush x:Key="SurfaceCardBrush" Color="#FFFFFF" Opacity="0.08"/>
    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF" Opacity="0.08"/>
    <SolidColorBrush x:Key="ThemeCard" Color="#FFFFFF" Opacity="0.08"/>
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#FFFFFF" Opacity="0.05"/>

    <Color x:Key="SurfaceSidebarColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="SurfaceSidebarBrush" Color="#FFFFFF" Opacity="0.06"/>
    <SolidColorBrush x:Key="ThemeSidebar" Color="#FFFFFF" Opacity="0.06"/>
    <SolidColorBrush x:Key="ThemeSidebarHover" Color="#FFFFFF" Opacity="0.12"/>
    <SolidColorBrush x:Key="ThemeSidebarActive" Color="#FFFFFF" Opacity="0.15"/>

    <!-- ─────────── CORE TYPOGRAPHY (Absolute readability) ─────────── -->
    <Color x:Key="ThemeTextPrimaryColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="ThemeTextPrimary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextHeadingBrush" Color="#FFFFFF"/>

    <Color x:Key="ThemeTextSecondaryColor">#CBD5E1</Color>
    <SolidColorBrush x:Key="ThemeTextSecondary" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="TextBodyBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="ThemeTextTertiary" Color="#64748B"/>
    
    <!-- Legacy Mappings -->
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#CBD5E1"/>

    <SolidColorBrush x:Key="ThemeForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeForegroundMuted" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="ThemeHover" Color="#FFFFFF" Opacity="0.08"/>

    <SolidColorBrush x:Key="TextInverseBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryForeground" Color="#0F172A"/>
    <SolidColorBrush x:Key="TextLinkBrush" Color="#818CF8"/>

    <!-- ─────────── BORDERS & DIVIDERS (Subtle 1px White) ─────────── -->
    <Color x:Key="ThemeBorderColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="ThemeBorder" Color="#FFFFFF" Opacity="0.15"/>
    <SolidColorBrush x:Key="ThemeDivider" Color="#FFFFFF" Opacity="0.10"/>
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="#FFFFFF" Opacity="0.15"/>

    <!-- ─────────── BRAND COLORS & ACCENTS (Vibrant Neon) ─────────── -->
    <Color x:Key="ThemePrimaryColor">#818CF8</Color>
    <Color x:Key="ThemeAccentColor">#38BDF8</Color>
    
    <!-- Reduced opacity for primary fills in glassmorphism to look glossy -->
    <SolidColorBrush x:Key="ThemePrimary" Color="#818CF8" Opacity="0.9"/>
    <SolidColorBrush x:Key="ThemeAccent" Color="#38BDF8" Opacity="0.9"/>
    
    <SolidColorBrush x:Key="PrimaryColor" Color="#818CF8"/>
    <SolidColorBrush x:Key="AccentColor" Color="#38BDF8"/>
    
    <!-- Legacy Brand Mappings -->
    <SolidColorBrush x:Key="ThemePrimaryLight" Color="#818CF8" Opacity="0.20"/>
    <SolidColorBrush x:Key="ThemePrimaryDark" Color="#4F46E5"/>

    <!-- ─────────── STATUS COLORS (Success, Warning, Error) ─────────── -->
    <Color x:Key="ThemeSuccessColor">#34D399</Color>
    <Color x:Key="ThemeWarningColor">#FBBF24</Color>
    <Color x:Key="ThemeErrorColor">#F87171</Color>
    <Color x:Key="ThemeInfoColor">#60A5FA</Color>

    <SolidColorBrush x:Key="ThemeSuccess" Color="#34D399"/>
    <SolidColorBrush x:Key="ThemeWarning" Color="#FBBF24"/>
    <SolidColorBrush x:Key="ThemeError" Color="#F87171"/>
    <SolidColorBrush x:Key="ThemeInfo" Color="#60A5FA"/>

    <SolidColorBrush x:Key="StatusSuccessBg" Color="#34D399" Opacity="0.15"/>
    <SolidColorBrush x:Key="StatusSuccessFg" Color="#6EE7B7"/>
    <SolidColorBrush x:Key="StatusWarningBg" Color="#FBBF24" Opacity="0.15"/>
    <SolidColorBrush x:Key="StatusWarningFg" Color="#FCD34D"/>
    <SolidColorBrush x:Key="StatusWarningFgDark" Color="#FCD34D"/>
    <SolidColorBrush x:Key="StatusErrorBg"   Color="#F87171" Opacity="0.15"/>
    <SolidColorBrush x:Key="StatusErrorFg"   Color="#FCA5A5"/>
    <SolidColorBrush x:Key="StatusInfoBg"    Color="#60A5FA" Opacity="0.15"/>
    <SolidColorBrush x:Key="StatusInfoFg"    Color="#93C5FD"/>

    <!-- ─────────── WORLD-CLASS LINEAR GRADIENTS (KPIs) ─────────── -->
    <LinearGradientBrush x:Key="KpiGradientPrimary" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4F46E5" Offset="0"/>
        <GradientStop Color="#9333EA" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="KpiGradientSuccess" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#059669" Offset="0"/>
        <GradientStop Color="#10B981" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KpiGradientWarning" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E11D48" Offset="0"/>
        <GradientStop Color="#EA580C" Offset="1"/>
    </LinearGradientBrush>

    <!-- Legacy Gradient Mappings -->
    <LinearGradientBrush x:Key="ThemePrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#A855F7" Offset="1"/>
    </LinearGradientBrush>

    <!-- ─────────── GLASSMORPHISM (Subtle Hover / Overlay states) ─────────── -->
    <SolidColorBrush x:Key="GlassBrushLow" Color="#FFFFFF" Opacity="0.05"/>
    <SolidColorBrush x:Key="GlassBrushMedium" Color="#FFFFFF" Opacity="0.10"/>
    <SolidColorBrush x:Key="GlassBrushHigh" Color="#FFFFFF" Opacity="0.15"/>
    <SolidColorBrush x:Key="GlassBrush" Color="#FFFFFF" Opacity="0.20"/>
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#FFFFFF" Opacity="0.08"/>
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="#FFFFFF" Opacity="0.15"/>
    <SolidColorBrush x:Key="SelectedRowBrush" Color="#818CF8" Opacity="0.2"/>

    <!-- Glass Card Gradient -->
    <LinearGradientBrush x:Key="GlassCardGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glass Borders -->
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#FFFFFF" Opacity="0.30"/>
    <SolidColorBrush x:Key="GlassBorderHighlight" Color="#FFFFFF" Opacity="0.50"/>
    <SolidColorBrush x:Key="CardStrokeBrush" Color="#FFFFFF" Opacity="0.20"/>

    <!-- ─────────── SHADOW SYSTEM (Soft Glows) ─────────── -->
    <Color x:Key="ShadowColor">#0F172A</Color>
    <DropShadowEffect x:Key="ShadowSubtle" BlurRadius="6" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.10"/>
    <DropShadowEffect x:Key="ShadowDefault" BlurRadius="12" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.15"/>
    <DropShadowEffect x:Key="ShadowMedium" BlurRadius="24" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.20"/>
    <DropShadowEffect x:Key="ShadowHigh" BlurRadius="36" ShadowDepth="8" Direction="270" Color="#000000" Opacity="0.30"/>

    <!-- ─────────── INTERACTION STATES ─────────── -->
    <SolidColorBrush x:Key="FocusRingBrush" Color="#818CF8" Opacity="0.6"/>
    <SolidColorBrush x:Key="DisabledOverlayBrush" Color="#091428" Opacity="0.5"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="RippleBrush" Color="#818CF8" Opacity="0.20"/>

    <!-- ─────────── STATUS LIGHT VARIANTS (Translucent) ─────────── -->
    <SolidColorBrush x:Key="StatusSuccessBgLight" Color="#34D399" Opacity="0.10"/>
    <SolidColorBrush x:Key="StatusSuccessFgLight" Color="#6EE7B7"/>
    <SolidColorBrush x:Key="StatusWarningBgLight" Color="#FBBF24" Opacity="0.10"/>
    <SolidColorBrush x:Key="StatusWarningFgLight" Color="#FCD34D"/>
    <SolidColorBrush x:Key="StatusErrorBgLight" Color="#F87171" Opacity="0.10"/>
    <SolidColorBrush x:Key="StatusErrorFgLight" Color="#FCA5A5"/>
    <SolidColorBrush x:Key="StatusInfoBgLight" Color="#60A5FA" Opacity="0.10"/>
    <SolidColorBrush x:Key="StatusInfoFgLight" Color="#93C5FD"/>

    <!-- ─────────── KPI GRADIENT - ERROR ─────────── -->
    <LinearGradientBrush x:Key="KpiGradientError" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F43F5E" Offset="0"/>
        <GradientStop Color="#EF4444" Offset="1"/>
    </LinearGradientBrush>

    <!-- ─────────── MISC MISSING TOKENS ─────────── -->
    <SolidColorBrush x:Key="ThemeHoverLight" Color="#FFFFFF" Opacity="0.08"/>
    <SolidColorBrush x:Key="ThemePrimaryMuted" Color="#818CF8" Opacity="0.20"/>
    <Color x:Key="ThemeTextTertiaryColor">#64748B</Color>

    <!-- ─────────── NEW PROFESSIONAL TOKENS ─────────── -->
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#FFFFFF" Opacity="0.3"/>
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="#818CF8"/>
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#FFFFFF" Opacity="0.05"/>
    <SolidColorBrush x:Key="StatusNeutralBg" Color="#FFFFFF" Opacity="0.10"/>

</ResourceDictionary>
