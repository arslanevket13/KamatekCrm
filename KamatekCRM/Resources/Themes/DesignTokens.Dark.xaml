<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════════════
         KAMATEK CRM — DESIGN TOKENS (DARK THEME)
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- ─────────── SEMANTIC SURFACE COLORS (Dark Theme) ─────────── -->
    <!-- Page background -->
    <Color x:Key="SurfacePageColor">#0B0E14</Color>
    <SolidColorBrush x:Key="SurfacePageBrush" Color="#0B0E14"/>

    <!-- Cards / Panels -->
    <Color x:Key="SurfaceCardColor">#141821</Color>
    <SolidColorBrush x:Key="SurfaceCardBrush" Color="#141821"/>

    <!-- Elevated surfaces (modals, dropdowns) -->
    <Color x:Key="SurfaceOverlayColor">#1E293B</Color>
    <SolidColorBrush x:Key="SurfaceOverlayBrush" Color="#1E293B"/>

    <!-- Sidebar -->
    <Color x:Key="SurfaceSidebarColor">#0D1117</Color>
    <SolidColorBrush x:Key="SurfaceSidebarBrush" Color="#0D1117"/>

    <!-- Glassmorphism -->
    <SolidColorBrush x:Key="GlassBrush" Color="#141821" Opacity="0.85"/>
    <SolidColorBrush x:Key="GlassBrushLow" Color="#FFFFFF" Opacity="0.10"/>
    <SolidColorBrush x:Key="GlassBrushMedium" Color="#FFFFFF" Opacity="0.15"/>
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#FFFFFF" Opacity="0.08"/>
    <SolidColorBrush x:Key="GlassBorderBrushStrong" Color="#FFFFFF" Opacity="0.30"/>
    <SolidColorBrush x:Key="GlassOverlayBrush" Color="#FFFFFF" Opacity="0.08"/>
    
    <!-- Card Shadow Color -->
    <Color x:Key="CardShadowColor">#000000</Color>

    <!-- ─────────── SEMANTIC TEXT COLORS ─────────── -->
    <SolidColorBrush x:Key="TextHeadingBrush" Color="#F0F0F5"/>
    <SolidColorBrush x:Key="TextBodyBrush" Color="#C8C8D0"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#8888A0"/>
    <SolidColorBrush x:Key="TextInverseBrush" Color="#0D0D12"/>
    <SolidColorBrush x:Key="TextLinkBrush" Color="#4BA0E8"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF"/>

    <!-- ─────────── SEMANTIC BORDER COLORS ─────────── -->
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#FFFFFF" Opacity="0.06"/>
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="#FFFFFF" Opacity="0.10"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#FFFFFF" Opacity="0.18"/>

    <!-- ─────────── SEMANTIC STATUS BACKGROUNDS ─────────── -->
    <SolidColorBrush x:Key="StatusSuccessBg" Color="#107C10" Opacity="0.15"/>
    <SolidColorBrush x:Key="StatusSuccessFg" Color="#5CD65C"/>
    <SolidColorBrush x:Key="StatusWarningBg" Color="#FF8C00" Opacity="0.15"/>
    <SolidColorBrush x:Key="StatusWarningFg" Color="#FFB74D"/>
    <SolidColorBrush x:Key="StatusErrorBg"   Color="#E81123" Opacity="0.15"/>
    <SolidColorBrush x:Key="StatusErrorFg"   Color="#FF6B6B"/>
    <SolidColorBrush x:Key="StatusInfoBg"    Color="#0078D4" Opacity="0.15"/>
    <SolidColorBrush x:Key="StatusInfoFg"    Color="#64B5F6"/>
    <SolidColorBrush x:Key="StatusNeutralBg" Color="#FFFFFF" Opacity="0.08"/>
    <SolidColorBrush x:Key="StatusNeutralFg" Color="#A0A0B0"/>

    <!-- ─────────── THEME COLORS ─────────── -->
    <Color x:Key="ThemePrimaryColor">#60CDFF</Color>
    <Color x:Key="ThemePrimaryDarkColor">#0078D4</Color>
    <Color x:Key="ThemePrimaryLightColor">#99E5FF</Color>
    <Color x:Key="ThemeAccentColor">#00D4E5</Color>
    
    <SolidColorBrush x:Key="ThemePrimary" Color="#60CDFF"/>
    <SolidColorBrush x:Key="ThemePrimaryDark" Color="#0078D4"/>
    <SolidColorBrush x:Key="ThemePrimaryLight" Color="#99E5FF"/>
    <SolidColorBrush x:Key="ThemeAccent" Color="#00D4E5"/>
    
    <SolidColorBrush x:Key="ThemeSuccess" Color="#6CCB5F"/>
    <SolidColorBrush x:Key="ThemeWarning" Color="#FCE100"/>
    <SolidColorBrush x:Key="ThemeError" Color="#FF99A4"/>
    <SolidColorBrush x:Key="ThemeInfo" Color="#60CDFF"/>
    <SolidColorBrush x:Key="ThemePurple" Color="#A78BFA"/>
    <SolidColorBrush x:Key="ThemePink" Color="#F472B6"/>
    <SolidColorBrush x:Key="ThemeCyan" Color="#22D3EE"/>
    <SolidColorBrush x:Key="ThemeTeal" Color="#2DD4BF"/>
    <SolidColorBrush x:Key="ThemeOrange" Color="#FB923C"/>
    <SolidColorBrush x:Key="ThemeIndigo" Color="#818CF8"/>

    <!-- ─────────── KPI CARD ACCENT GRADIENTS ─────────── -->
    <LinearGradientBrush x:Key="KpiGradientBlue" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0078D4" Offset="0"/>
        <GradientStop Color="#00B7C3" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KpiGradientGreen" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#107C10" Offset="0"/>
        <GradientStop Color="#00C853" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KpiGradientOrange" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF8C00" Offset="0"/>
        <GradientStop Color="#FFB74D" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KpiGradientPurple" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#A78BFA" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KpiGradientRed" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E81123" Offset="0"/>
        <GradientStop Color="#FF6B6B" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KpiGradientCyan" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00B7C3" Offset="0"/>
        <GradientStop Color="#00E5FF" Offset="1"/>
    </LinearGradientBrush>

    <!-- ─────────── INTERACTIVE STATE OVERLAYS ─────────── -->
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#FFFFFF" Opacity="0.04"/>
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="#FFFFFF" Opacity="0.08"/>
    <SolidColorBrush x:Key="FocusRingBrush" Color="#4BA0E8"/>
    <SolidColorBrush x:Key="SelectedRowBrush" Color="#0078D4" Opacity="0.15"/>

    <!-- ─────────── ELEVATION (Shadow System) ─────────── -->
    <DropShadowEffect x:Key="Elevation0" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
    <DropShadowEffect x:Key="Elevation1" BlurRadius="4"  ShadowDepth="1"  Direction="270" Color="#000000" Opacity="0.20"/>
    <DropShadowEffect x:Key="Elevation2" BlurRadius="8"  ShadowDepth="2"  Direction="270" Color="#000000" Opacity="0.30"/>
    <DropShadowEffect x:Key="Elevation3" BlurRadius="16" ShadowDepth="4"  Direction="270" Color="#000000" Opacity="0.40"/>
    <DropShadowEffect x:Key="Elevation4" BlurRadius="24" ShadowDepth="8"  Direction="270" Color="#000000" Opacity="0.50"/>
    <DropShadowEffect x:Key="Elevation5" BlurRadius="40" ShadowDepth="16" Direction="270" Color="#000000" Opacity="0.60"/>

    <!-- ─────────── SPACING SCALE (4px base unit) ─────────── -->
    <sys:Double x:Key="SpaceXXS">2</sys:Double>
    <sys:Double x:Key="SpaceXS">4</sys:Double>
    <sys:Double x:Key="SpaceSM">8</sys:Double>
    <sys:Double x:Key="SpaceMD">12</sys:Double>
    <sys:Double x:Key="SpaceLG">16</sys:Double>
    <sys:Double x:Key="SpaceXL">24</sys:Double>
    <sys:Double x:Key="SpaceXXL">32</sys:Double>
    <sys:Double x:Key="Space3XL">48</sys:Double>
    <sys:Double x:Key="Space4XL">64</sys:Double>

    <!-- ─────────── ICON SIZES ─────────── -->
    <sys:Double x:Key="IconXS">12</sys:Double>
    <sys:Double x:Key="IconSM">16</sys:Double>
    <sys:Double x:Key="IconMD">20</sys:Double>
    <sys:Double x:Key="IconLG">24</sys:Double>
    <sys:Double x:Key="IconXL">32</sys:Double>
    <sys:Double x:Key="IconXXL">48</sys:Double>

    <!-- ─────────── COMPONENT-SPECIFIC DIMENSIONS ─────────── -->
    <sys:Double x:Key="DataGridRowHeight">48</sys:Double>
    <sys:Double x:Key="DataGridHeaderHeight">44</sys:Double>
    <sys:Double x:Key="SidebarWidth">260</sys:Double>
    <sys:Double x:Key="SidebarCollapsedWidth">68</sys:Double>
    <sys:Double x:Key="KpiCardMinWidth">240</sys:Double>
    <sys:Double x:Key="KpiCardHeight">120</sys:Double>
    <sys:Double x:Key="AvatarSizeSM">28</sys:Double>
    <sys:Double x:Key="AvatarSizeMD">36</sys:Double>
    <sys:Double x:Key="AvatarSizeLG">48</sys:Double>
    <sys:Double x:Key="AvatarSizeXL">64</sys:Double>

    <!-- ─────────── DROP SHADOWS ─────────── -->
    <DropShadowEffect x:Key="DropShadow" BlurRadius="15" ShadowDepth="2" Direction="315" Color="#000000" Opacity="0.5"/>
    <DropShadowEffect x:Key="DropShadowLight" BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.3"/>
    <DropShadowEffect x:Key="DropShadowHeavy" BlurRadius="30" ShadowDepth="4" Direction="315" Color="#000000" Opacity="0.6"/>

    <!-- ─────────── LEGACY COMPATIBILITY ─────────── -->
    <SolidColorBrush x:Key="PrimaryColor" Color="{StaticResource ThemePrimaryColor}"/>
    <SolidColorBrush x:Key="TextPrimaryColor" Color="{StaticResource ThemeTextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryColor" Color="{StaticResource ThemeTextSecondaryColor}"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="{StaticResource SurfacePageColor}"/>
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource ThemeTextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource ThemeTextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextPrimaryColor" Color="{StaticResource ThemeTextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryColor" Color="{StaticResource ThemeTextSecondaryColor}"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="{StaticResource SurfacePageColor}"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="{StaticResource SurfacePageColor}"/>

    <!-- ─────────── ANIMATION TOKENS ─────────── -->
    <Duration x:Key="DurationFast">0:0:0.15</Duration>
    <Duration x:Key="DurationNormal">0:0:0.25</Duration>
    <Duration x:Key="DurationSlow">0:0:0.4</Duration>
    <Duration x:Key="DurationVerySlow">0:0:0.6</Duration>

    <QuadraticEase x:Key="EaseOut" EasingMode="EaseOut"/>
    <CubicEase x:Key="EaseInOut" EasingMode="EaseInOut"/>
    <BackEase x:Key="EaseOutBack" EasingMode="EaseOut" Amplitude="0.3"/>
    <ElasticEase x:Key="EaseOutElastic" EasingMode="EaseOut" Oscillations="1" Springiness="5"/>

</ResourceDictionary>
