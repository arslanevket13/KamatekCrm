<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ════════════════════════════════════════════════════════════════
         KAMATEK CRM — MIDNIGHT BLUE DARK THEME v3.0
         Premium ERP dark palette with glassmorphism & neon accents.
         All surfaces, text, borders, and states — Dark mode native.
    ════════════════════════════════════════════════════════════════ -->

    <!-- ─────────── PRIMARY BRAND COLORS ─────────── -->
    <Color x:Key="PrimaryColor">#3B82F6</Color>
    <Color x:Key="PrimaryDarkColor">#2563EB</Color>
    <Color x:Key="PrimaryLightColor">#60A5FA</Color>
    <Color x:Key="PrimaryAccentColor">#06B6D4</Color>

    <!-- ─────────── SECONDARY COLORS ─────────── -->
    <Color x:Key="SecondaryColor">#64748B</Color>
    <Color x:Key="SecondaryDarkColor">#475569</Color>
    <Color x:Key="SecondaryLightColor">#94A3B8</Color>

    <!-- ─────────── SEMANTIC STATUS COLORS ─────────── -->
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="InfoColor">#06B6D4</Color>

    <!-- ─────────── GRADIENT ACCENTS ─────────── -->
    <Color x:Key="GradientStartColor">#3B82F6</Color>
    <Color x:Key="GradientMiddleColor">#8B5CF6</Color>
    <Color x:Key="GradientEndColor">#06B6D4</Color>

    <!-- ─────────── MIDNIGHT BLUE SURFACES ─────────── -->
    <Color x:Key="WhiteColor">#E2E8F0</Color>
    <Color x:Key="BlackColor">#000000</Color>
    <Color x:Key="BackgroundPrimaryColor">#0B0E14</Color>
    <Color x:Key="BackgroundSecondaryColor">#0F1319</Color>
    <Color x:Key="BackgroundTertiaryColor">#141821</Color>
    <Color x:Key="SurfaceColor">#141821</Color>
    <Color x:Key="CardColor">#141821</Color>

    <!-- ─────────── TEXT COLORS (High Contrast on Dark) ─────────── -->
    <Color x:Key="TextPrimaryColor">#F1F5F9</Color>
    <Color x:Key="TextSecondaryColor">#94A3B8</Color>
    <Color x:Key="TextTertiaryColor">#64748B</Color>
    <Color x:Key="TextDisabledColor">#334155</Color>

    <!-- ─────────── BORDER COLORS ─────────── -->
    <Color x:Key="BorderPrimaryColor">#1E293B</Color>
    <Color x:Key="BorderSecondaryColor">#334155</Color>
    <Color x:Key="BorderFocusColor">#3B82F6</Color>

    <!-- ─────────── STATE COLORS ─────────── -->
    <Color x:Key="HoverColor">#1E293B</Color>
    <Color x:Key="ActiveColor">#334155</Color>
    <Color x:Key="SelectedColor">#1E3A5F</Color>

    <!-- ═══════════ BRUSHES ═══════════ -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#06B6D4"/>

    <SolidColorBrush x:Key="SecondaryBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="SecondaryDarkBrush" Color="#475569"/>
    <SolidColorBrush x:Key="SecondaryLightBrush" Color="#94A3B8"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#06B6D4"/>

    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="#0B0E14"/>
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="#0F1319"/>
    <SolidColorBrush x:Key="BackgroundTertiaryBrush" Color="#141821"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#141821"/>
    <SolidColorBrush x:Key="CardBrush" Color="#141821"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#334155"/>

    <SolidColorBrush x:Key="BorderPrimaryBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="BorderSecondaryBrush" Color="#334155"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="#3B82F6"/>

    <SolidColorBrush x:Key="HoverBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="ActiveBrush" Color="#334155"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="#1E3A5F"/>

    <!-- ─────────── GRADIENTS ─────────── -->
    <LinearGradientBrush x:Key="BrandGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#3B82F6" Offset="0"/>
        <GradientStop Color="#8B5CF6" Offset="0.5"/>
        <GradientStop Color="#06B6D4" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#3B82F6" Offset="0"/>
        <GradientStop Color="#06B6D4" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#06B6D4" Offset="0"/>
        <GradientStop Color="#8B5CF6" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0D1117" Offset="0"/>
        <GradientStop Color="#080B10" Offset="1"/>
    </LinearGradientBrush>

    <!-- Neon Glow Gradients -->
    <LinearGradientBrush x:Key="NeonBlueGlow" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#3B82F6" Offset="0"/>
        <GradientStop Color="#2563EB" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="NeonCyanGlow" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#06B6D4" Offset="0"/>
        <GradientStop Color="#0891B2" Offset="1"/>
    </LinearGradientBrush>

    <!-- ─────────── SHADOWS ─────────── -->
    <DropShadowEffect x:Key="SubtleShadow" BlurRadius="8" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.3"/>
    <DropShadowEffect x:Key="MediumShadow" BlurRadius="16" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.4"/>
    <DropShadowEffect x:Key="StrongShadow" BlurRadius="24" ShadowDepth="8" Direction="270" Color="#000000" Opacity="0.5"/>
    <DropShadowEffect x:Key="GlowEffect" BlurRadius="24" ShadowDepth="0" Color="#3B82F6" Opacity="0.35"/>
    <DropShadowEffect x:Key="NeonGlow" BlurRadius="20" ShadowDepth="0" Color="#06B6D4" Opacity="0.4"/>

    <!-- ─────────── CORNER RADIUS ─────────── -->
    <CornerRadius x:Key="SmallRadius">4</CornerRadius>
    <CornerRadius x:Key="MediumRadius">8</CornerRadius>
    <CornerRadius x:Key="LargeRadius">12</CornerRadius>
    <CornerRadius x:Key="XLRadius">16</CornerRadius>
    <CornerRadius x:Key="CardRadius">12</CornerRadius>

    <!-- ─────────── FONTS ─────────── -->
    <FontFamily x:Key="PrimaryFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, Consolas</FontFamily>

    <sys:Double x:Key="FontSizeTiny">10</sys:Double>
    <sys:Double x:Key="FontSizeSmall">12</sys:Double>
    <sys:Double x:Key="FontSizeNormal">14</sys:Double>
    <sys:Double x:Key="FontSizeMedium">16</sys:Double>
    <sys:Double x:Key="FontSizeLarge">20</sys:Double>
    <sys:Double x:Key="FontSizeXLarge">24</sys:Double>
    <sys:Double x:Key="FontSizeXXLarge">32</sys:Double>
    <sys:Double x:Key="FontSizeTitle">40</sys:Double>

    <!-- ─────────── SPACING ─────────── -->
    <Thickness x:Key="TinyMargin">4</Thickness>
    <Thickness x:Key="SmallMargin">8</Thickness>
    <Thickness x:Key="MediumMargin">16</Thickness>
    <Thickness x:Key="LargeMargin">24</Thickness>
    <Thickness x:Key="XLMargin">32</Thickness>

    <Thickness x:Key="SmallPadding">8</Thickness>
    <Thickness x:Key="MediumPadding">16</Thickness>
    <Thickness x:Key="LargePadding">24</Thickness>

    <!-- ─────────── BACKWARD COMPATIBILITY KEYS ─────────── -->
    <SolidColorBrush x:Key="BorderColor" Color="#1E293B"/>
    <SolidColorBrush x:Key="PrimaryColorKey" Color="#3B82F6"/>
    <SolidColorBrush x:Key="SecondaryColorKey" Color="#64748B"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#0B0E14"/>

    <DropShadowEffect x:Key="DropShadow" BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.35"/>

    <!-- Legacy Theme Colors -->
    <Color x:Key="ThemePrimaryColor">#3B82F6</Color>
    <Color x:Key="ThemePrimaryDarkColor">#2563EB</Color>
    <Color x:Key="ThemeAccentColor">#06B6D4</Color>
    <Color x:Key="ThemeBackgroundColor">#0B0E14</Color>
    <Color x:Key="ThemeTextPrimaryColor">#F1F5F9</Color>
    <Color x:Key="ThemeTextSecondaryColor">#94A3B8</Color>
    <Color x:Key="ThemeTextTertiaryColor">#64748B</Color>

    <SolidColorBrush x:Key="ThemePrimary" Color="#3B82F6"/>
    <SolidColorBrush x:Key="ThemePrimaryDark" Color="#2563EB"/>
    <SolidColorBrush x:Key="ThemeAccent" Color="#06B6D4"/>

    <!-- Theme Text (Dark) -->
    <SolidColorBrush x:Key="ThemeTextPrimary" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="ThemeTextSecondary" Color="#94A3B8"/>
    <SolidColorBrush x:Key="ThemeTextTertiary" Color="#64748B"/>
    <SolidColorBrush x:Key="ThemeBackground" Color="#0B0E14"/>
    <SolidColorBrush x:Key="ThemeCardBackground" Color="#141821"/>
    
    <SolidColorBrush x:Key="ThemeTextPrimaryDark" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="ThemeTextSecondaryDark" Color="#94A3B8"/>
    <SolidColorBrush x:Key="ThemeTextTertiaryDark" Color="#64748B"/>
    <SolidColorBrush x:Key="ThemeBackgroundDark" Color="#0B0E14"/>
    <SolidColorBrush x:Key="ThemeCardBackgroundDark" Color="#141821"/>

    <!-- ═══════════════════════════════════════════════════════════════
         FLUENT UI CONTROL STYLES — DARK MODE
    ═══════════════════════════════════════════════════════════════ -->

    <!-- Fluent Button (Primary) -->
    <Style x:Key="FluentButton" TargetType="Button">
        <Setter Property="Background" Value="#3B82F6"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Fluent Secondary Button -->
    <Style x:Key="FluentSecondaryButton" TargetType="Button" BasedOn="{StaticResource FluentButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#60A5FA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#3B82F6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1E3A5F"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1E40AF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Fluent TextBox (Dark) -->
    <Style x:Key="FluentTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="#141821"/>
        <Setter Property="Foreground" Value="#F1F5F9"/>
        <Setter Property="CaretBrush" Value="#60A5FA"/>
        <Setter Property="BorderBrush" Value="#1E293B"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="#334155"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#0F1319"/>
                            <Setter Property="Foreground" Value="#334155"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Fluent Card (Dark Glassmorphism) -->
    <Style x:Key="FluentCard" TargetType="Border">
        <Setter Property="Background" Value="#141821"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.06"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.3"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Glassmorphism Card (Dark) -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#141821" Opacity="0.85"/>
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.08"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="30" ShadowDepth="8" Direction="270" Color="#000000" Opacity="0.4"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Glass Card Dark (Deepest) -->
    <Style x:Key="GlassCardDark" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#0B0E14" Opacity="0.9"/>
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#3B82F6" Opacity="0.12"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="30" ShadowDepth="8" Direction="270" Color="#000000" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Fluent ComboBox (Dark) -->
    <Style x:Key="FluentComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="#141821"/>
        <Setter Property="Foreground" Value="#F1F5F9"/>
        <Setter Property="BorderBrush" Value="#1E293B"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- Fluent DataGrid (Dark) -->
    <Style x:Key="FluentDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="#141821"/>
        <Setter Property="Foreground" Value="#F1F5F9"/>
        <Setter Property="BorderBrush" Value="#1E293B"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#1E293B"/>
        <Setter Property="RowHeight" Value="44"/>
        <Setter Property="ColumnHeaderHeight" Value="48"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- Fluent DataGrid Row (Dark) -->
    <Style x:Key="FluentDataGridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#F1F5F9"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1E293B"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#1E3A5F"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Sidebar Nav Button (Dark) -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#94A3B8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}"
                            Margin="4,2">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                            <Setter Property="Foreground" Value="#F1F5F9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Status Badge (Dark) -->
    <Style x:Key="StatusBadge" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <!-- Pulse Animation -->
    <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0.6" To="1" Duration="0:0:0.8" AutoReverse="True"/>
    </Storyboard>

</ResourceDictionary>
