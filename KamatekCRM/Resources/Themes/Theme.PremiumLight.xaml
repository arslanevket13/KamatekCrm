<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════
         KAMATEK CRM — THE MASTERPIECE PALETTE (PREMIUM LIGHT THEME)
         Elite SaaS Design (Stripe/Linear/Apple macOS inspired).
         STRICT RULE: Only Colors and Brushes.
    ═══════════════════════════════════════════════════════════════════ -->

    <!-- ─────────── PAGE & BACKGROUNDS (The Canvas) ─────────── -->
    <Color x:Key="SurfacePageColor">#F8FAFC</Color>
    <SolidColorBrush x:Key="SurfacePageBrush" Color="#F8FAFC"/>
    <Color x:Key="ThemeBackgroundColor">#F8FAFC</Color>
    <SolidColorBrush x:Key="ThemeBackground" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#F8FAFC"/>

    <!-- ─────────── SURFACES & CARDS (Pure White for Content Pop) ─────────── -->
    <Color x:Key="SurfaceCardColor">#FFFFFF</Color>
    <Color x:Key="ThemeSurfaceColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="ThemeSurface" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceCardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeCard" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#FFFFFF"/>

    <Color x:Key="SurfaceSidebarColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="SurfaceSidebarBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeSidebar" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeSidebarHover" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="ThemeSidebarActive" Color="#E2E8F0"/>

    <!-- ─────────── CORE TYPOGRAPHY (Absolute readability) ─────────── -->
    <Color x:Key="ThemeTextPrimaryColor">#020617</Color>
    <SolidColorBrush x:Key="ThemeTextPrimary" Color="#020617"/>
    <SolidColorBrush x:Key="TextHeadingBrush" Color="#020617"/>

    <Color x:Key="ThemeTextSecondaryColor">#475569</Color>
    <SolidColorBrush x:Key="ThemeTextSecondary" Color="#475569"/>
    <SolidColorBrush x:Key="TextBodyBrush" Color="#334155"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="ThemeTextTertiary" Color="#64748B"/>
    
    <!-- Legacy Mappings -->
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#020617"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#475569"/>
    
    <SolidColorBrush x:Key="ThemeForeground" Color="#020617"/>
    <SolidColorBrush x:Key="ThemeForegroundMuted" Color="#475569"/>
    <SolidColorBrush x:Key="ThemeHover" Color="#0F172A" Opacity="0.04"/>

    <SolidColorBrush x:Key="TextInverseBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextLinkBrush" Color="#4F46E5"/>

    <!-- ─────────── BORDERS & DIVIDERS (Premium Subtlety) ─────────── -->
    <Color x:Key="ThemeBorderColor">#E2E8F0</Color>
    <SolidColorBrush x:Key="ThemeBorder" Color="#E2E8F0" Opacity="0.8"/>
    <SolidColorBrush x:Key="ThemeDivider" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="#E2E8F0"/>

    <!-- ─────────── BRAND COLORS & ACCENTS ─────────── -->
    <Color x:Key="ThemePrimaryColor">#4F46E5</Color>
    <Color x:Key="ThemeAccentColor">#06B6D4</Color>
    
    <SolidColorBrush x:Key="ThemePrimary" Color="#4F46E5"/>
    <SolidColorBrush x:Key="ThemeAccent" Color="#06B6D4"/>
    
    <SolidColorBrush x:Key="PrimaryColor" Color="#4F46E5"/>
    <SolidColorBrush x:Key="AccentColor" Color="#06B6D4"/>
    
    <!-- Legacy Brand Mappings -->
    <SolidColorBrush x:Key="ThemePrimaryLight" Color="#4F46E5" Opacity="0.10"/>
    <SolidColorBrush x:Key="ThemePrimaryDark" Color="#3730A3"/>

    <!-- ─────────── STATUS COLORS (Success, Warning, Error) ─────────── -->
    <Color x:Key="ThemeSuccessColor">#10B981</Color>
    <Color x:Key="ThemeWarningColor">#F59E0B</Color>
    <Color x:Key="ThemeErrorColor">#EF4444</Color>
    <Color x:Key="ThemeInfoColor">#3B82F6</Color>

    <SolidColorBrush x:Key="ThemeSuccess" Color="#10B981"/>
    <SolidColorBrush x:Key="ThemeWarning" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ThemeError" Color="#EF4444"/>
    <SolidColorBrush x:Key="ThemeInfo" Color="#3B82F6"/>

    <SolidColorBrush x:Key="StatusSuccessBg" Color="#10B981" Opacity="0.12"/>
    <SolidColorBrush x:Key="StatusSuccessFg" Color="#059669"/>
    <SolidColorBrush x:Key="StatusWarningBg" Color="#F59E0B" Opacity="0.15"/>
    <SolidColorBrush x:Key="StatusWarningFg" Color="#D97706"/>
    <SolidColorBrush x:Key="StatusWarningFgDark" Color="#D97706"/>
    <SolidColorBrush x:Key="StatusErrorBg"   Color="#EF4444" Opacity="0.12"/>
    <SolidColorBrush x:Key="StatusErrorFg"   Color="#DC2626"/>
    <SolidColorBrush x:Key="StatusInfoBg"    Color="#3B82F6" Opacity="0.12"/>
    <SolidColorBrush x:Key="StatusInfoFg"    Color="#2563EB"/>

    <!-- ─────────── WORLD-CLASS LINEAR GRADIENTS (KPIs) ─────────── -->
    <LinearGradientBrush x:Key="KpiGradientPrimary" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4F46E5" Offset="0"/>
        <GradientStop Color="#06B6D4" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="KpiGradientSuccess" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#10B981" Offset="0"/>
        <GradientStop Color="#14B8A6" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KpiGradientWarning" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F43F5E" Offset="0"/>
        <GradientStop Color="#F97316" Offset="1"/>
    </LinearGradientBrush>

    <!-- Legacy Gradient Mappings -->
    <LinearGradientBrush x:Key="ThemePrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4F46E5" Offset="0"/>
        <GradientStop Color="#3B82F6" Offset="1"/>
    </LinearGradientBrush>

    <!-- ─────────── GLASSMORPHISM (Subtle Hover / Overlay states) ─────────── -->
    <SolidColorBrush x:Key="GlassBrushLow" Color="#0F172A" Opacity="0.03"/>
    <SolidColorBrush x:Key="GlassBrushMedium" Color="#0F172A" Opacity="0.06"/>
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#0F172A" Opacity="0.04"/>
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="#0F172A" Opacity="0.08"/>
    <SolidColorBrush x:Key="SelectedRowBrush" Color="#4F46E5" Opacity="0.06"/>

</ResourceDictionary>
