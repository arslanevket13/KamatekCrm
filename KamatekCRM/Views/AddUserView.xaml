<Window x:Class="KamatekCrm.Views.AddUserView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:KamatekCrm.ViewModels"
        xmlns:converters="clr-namespace:KamatekCrm.Converters"
        Title="Yeni Kullanıcı Ekle" 
        SizeToContent="Height"
        Width="450"
        MinHeight="500"
        MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource SurfacePageBrush}">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    


    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="👤 Yeni Kullanıcı Ekle" 
                       FontSize="22" FontWeight="Bold" 
                       Foreground="{DynamicResource StatusInfoFg}"/>
            <TextBlock Text="Admin tarafından kullanıcı oluşturma" 
                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Form -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="HeaderTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="14" FontWeight="SemiBold" Margin="8,4"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Padding" Value="12,8"/>
                </Style>
            </TabControl.Resources>

            <!-- TAB 1: Temel Bilgiler -->
            <TabItem Header="👤 Temel Bilgiler">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" 
                        Padding="20" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" Margin="0,12,0,0">
                    <StackPanel>
                        <!-- Ad -->
                        <TextBlock Text="Ad *" FontWeight="SemiBold" Foreground="{DynamicResource TextHeadingBrush}" Margin="0,0,0,6"/>
                        <TextBox x:Name="AdTextBox"
                                 Text="{Binding Ad, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource PremiumTextBox}"
                                 Height="40" Margin="0,0,0,12"/>

                        <!-- Soyad -->
                        <TextBlock Text="Soyad *" FontWeight="SemiBold" Foreground="{DynamicResource TextHeadingBrush}" Margin="0,4,0,6"/>
                        <TextBox Text="{Binding Soyad, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource PremiumTextBox}"
                                 Height="40" Margin="0,0,0,12"/>

                        <!-- Kullanıcı Adı -->
                        <TextBlock Text="Kullanıcı Adı *" FontWeight="SemiBold" Foreground="{DynamicResource TextHeadingBrush}" Margin="0,4,0,6"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource PremiumTextBox}"
                                 Height="40"/>
                        
                        <TextBlock Text="{Binding UsernameValidationMessage}" 
                                   FontSize="11" Margin="0,4,0,0"
                                   Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource StatusSuccessFg}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUsernameAvailable}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource StatusErrorFg}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Rol -->
                        <TextBlock Text="Rol *" FontWeight="SemiBold" Foreground="{DynamicResource TextHeadingBrush}" Margin="0,12,0,6"/>
                        <ComboBox ItemsSource="{Binding RoleDisplayOptions}"
                                  SelectedItem="{Binding SelectedRoleDisplay}"
                                  Style="{StaticResource ModernComboBox}"
                                  Height="40"/>

                        <!-- Bilgi notu -->
                        <Border Background="{DynamicResource StatusInfoBg}" CornerRadius="6" Padding="12,10" Margin="0,16,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource StatusInfoFg}">
                                <Run FontWeight="SemiBold">ℹ️ Varsayılan şifre: 1234</Run>
                                <LineBreak/>
                                <Run>Kullanıcı giriş yaptıktan sonra şifresini değiştirebilir.</Run>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- TAB 2: Yetkiler (RBAC) -->
            <TabItem Header="🛡️ Yetkiler">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" 
                        Padding="20" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Modül Erişim Yetkileri" FontSize="15" FontWeight="Bold" Margin="0,0,0,16" Foreground="{DynamicResource ThemePrimary}"/>
                        
                        <CheckBox Content="Finansal Kayıtları Gör" IsChecked="{Binding CanViewFinance}" Margin="0,0,0,12" Style="{StaticResource {x:Type CheckBox}}"/>
                        <CheckBox Content="Analiz ve Raporları Gör" IsChecked="{Binding CanViewAnalytics}" Margin="0,0,0,12"/>
                        <CheckBox Content="Kayıt Silme Yetkisi" IsChecked="{Binding CanDeleteRecords}" Margin="0,0,0,12"/>
                        <CheckBox Content="Satın Alma Onay Yetkisi" IsChecked="{Binding CanApprovePurchase}" Margin="0,0,0,12"/>
                        <CheckBox Content="Sistem Ayarlarına Erişim" IsChecked="{Binding CanAccessSettings}" Margin="0,0,0,12"/>
                        
                        <Border Background="{DynamicResource StatusWarningBg}" CornerRadius="6" Padding="12,10" Margin="0,8,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource StatusWarningFg}">
                                <Run FontWeight="SemiBold">⚠️ Uyarı:</Run>
                                <Run>Yetkiler kullanıcının rolünden bağımsız olarak verilebilir.</Run>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- TAB 3: Saha Bilgileri (Sadece Teknisyenler için) -->
            <TabItem Header="🔧 Saha Bilgileri" Visibility="{Binding IsTechnicianRole, Converter={StaticResource BoolToVis}}">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" 
                        Padding="20" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Teknisyen Detayları" FontSize="15" FontWeight="Bold" Margin="0,0,0,16" Foreground="{DynamicResource ThemeSuccess}"/>

                        <!-- Araç Plakası -->
                        <TextBlock Text="Araç Plakası" FontWeight="SemiBold" Foreground="{DynamicResource TextHeadingBrush}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding VehiclePlate}" Style="{StaticResource PremiumTextBox}" Height="40" Margin="0,0,0,12" Tag="34 KV 1234"/>

                        <!-- Hizmet Bölgesi -->
                        <TextBlock Text="Hizmet Bölgesi" FontWeight="SemiBold" Foreground="{DynamicResource TextHeadingBrush}" Margin="0,4,0,6"/>
                        <TextBox Text="{Binding ServiceArea}" Style="{StaticResource PremiumTextBox}" Height="40" Margin="0,0,0,12" Tag="Eskişehir Merkez"/>

                        <!-- Uzmanlık Alanları -->
                        <TextBlock Text="Uzmanlık Alanları" FontWeight="SemiBold" Foreground="{DynamicResource TextHeadingBrush}" Margin="0,4,0,6"/>
                        <TextBox Text="{Binding ExpertiseAreas}" Style="{StaticResource PremiumTextBox}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Tag="Kombi, Klima, Beyaz Eşya"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Status Message Overlay -->
        <Border Grid.Row="1" VerticalAlignment="Bottom" Margin="10" CornerRadius="6" Padding="12,10" Panel.ZIndex="10"
                Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}"
                Effect="{DynamicResource Elevation2}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource StatusErrorBg}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource StatusSuccessBg}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="12">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource StatusErrorFg}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource StatusSuccessFg}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="🗑️ Temizle" 
                    Command="{Binding ClearCommand}"
                    Height="44" FontSize="14"
                    Background="{DynamicResource ApplicationBackgroundBrush}" Foreground="{DynamicResource TextHeadingBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="2" Content="💾 Kaydet" 
                    Command="{Binding SaveCommand}"
                    Height="44" FontSize="14" FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="{DynamicResource ThemeSuccess}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeSuccess}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{DynamicResource BorderDefaultBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>


