<Window x:Class="KamatekCrm.Views.PasswordResetView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:KamatekCrm.Converters"
        Title="Şifre Değiştir" 
        SizeToContent="Height"
        Width="400"
        MinHeight="350"
        MaxHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource SurfacePageBrush}">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🔑 Şifre Değiştir" 
                       FontSize="22" FontWeight="Bold" 
                       Foreground="{DynamicResource StatusInfoFg}"/>
            <TextBlock Text="{Binding AdSoyad}" 
                       FontSize="14" Foreground="{DynamicResource TextBodyBrush}" Margin="0,4,0,0"/>
            <TextBlock Text="{Binding Username, StringFormat='@{0}'}" 
                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Form -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" 
                Padding="20" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
            <StackPanel>
                <!-- Yeni Şifre -->
                <TextBlock Text="Yeni Şifre *" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="NewPasswordBox"
                             PasswordChanged="NewPasswordBox_PasswordChanged"
                             Height="40" FontSize="14" Padding="12,8"
                             BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <!-- Şifre Tekrar -->
                <TextBlock Text="Şifre Tekrar *" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,16,0,6"/>
                <PasswordBox x:Name="ConfirmPasswordBox"
                             PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                             Height="40" FontSize="14" Padding="12,8"
                             BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
                
                <!-- Şifre eşleşme mesajı -->
                <TextBlock Text="{Binding PasswordMatchMessage}" 
                           FontSize="11" Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource StatusSuccessFg}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PasswordsMatch}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource StatusErrorFg}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Bilgi notu -->
                <Border Background="{DynamicResource StatusWarningBg}" CornerRadius="6" Padding="12,10" Margin="0,16,0,0">
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource StatusWarningFg}">
                        <Run FontWeight="SemiBold">⚠️ Uyarı:</Run>
                        <LineBreak/>
                        <Run>• Şifre en az 4 karakter olmalı</Run>
                        <LineBreak/>
                        <Run>• Kullanıcıya yeni şifreyi bildirin</Run>
                    </TextBlock>
                </Border>

                <!-- Status Message -->
                <Border Margin="0,12,0,0" CornerRadius="6" Padding="12,10"
                        Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource StatusErrorBg}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource StatusSuccessBg}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource StatusErrorFg}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource StatusSuccessFg}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="❌ İptal" 
                    Command="{Binding CancelCommand}"
                    Height="44" FontSize="14"
                    Background="{DynamicResource ApplicationBackgroundBrush}" Foreground="{DynamicResource TextBodyBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="2" Content="💾 Kaydet" 
                    Command="{Binding SaveCommand}"
                    Height="44" FontSize="14" FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="{DynamicResource ThemeWarning}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeWarning}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{DynamicResource BorderDefaultBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>


