<UserControl x:Class="KamatekCrm.Views.RoutePlanningView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="{DynamicResource SurfacePageBrush}">
    
    <UserControl.Resources>
        <!-- Accent Brush -->
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource ThemePrimaryColor}"/>
        <SolidColorBrush x:Key="AccentLightBrush" Color="{DynamicResource ThemePrimaryLightColor}"/>
        
        <!-- Card Style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeSurface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.08" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Action Button Style -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" 
                                Padding="{TemplateBinding Padding}" x:Name="Bd">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- ============ SOL PANEL ============ -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Stats -->
                <RowDefinition Height="Auto"/>  <!-- Actions -->
                <RowDefinition Height="*"/>     <!-- Lists -->
            </Grid.RowDefinitions>
            
            <!-- === HEADER === -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="📍 ROTA PLANLAMA" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource ThemePrimary}" Margin="0,0,0,10"/>
                    
                    <!-- Teknisyen Seçimi -->
                    <TextBlock Text="Teknisyen" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Technicians}" SelectedItem="{Binding SelectedTechnician}"
                              Padding="8,6" FontSize="13">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤 " FontSize="13"/>
                                    <TextBlock FontSize="13">
                                        <Run Text="{Binding Ad}"/> <Run Text="{Binding Soyad}"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    
                    <!-- Tarih Seçimi -->
                    <TextBlock Text="Tarih" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,10,0,4"/>
                    <DatePicker SelectedDate="{Binding SelectedDate}" Padding="6,4" FontSize="13"/>
                </StackPanel>
            </Border>
            
            <!-- === İSTATİSTİKLER === -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Toplam -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalPoints}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ThemePrimary}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Nokta" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Tamamlanan -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding CompletedPoints}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ThemeSuccess}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bitti" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Mesafe -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalDistanceDisplay}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Mesafe" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Süre -->
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding EstimatedDurationDisplay}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource ThemePrimary}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Süre" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- === EYLEM BUTONLARI === -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="💾 Kaydet" Command="{Binding SaveRouteCommand}" 
                            Background="{DynamicResource ThemeSuccess}" Style="{StaticResource ActionBtn}" Margin="0,0,4,0"/>
                    <Button Content="⚡ Optimize" Command="{Binding OptimizeRouteCommand}" 
                            Background="{DynamicResource ThemeWarning}" Style="{StaticResource ActionBtn}" Margin="0,0,4,0"/>
                    <Button Content="🗑 Temizle" Command="{Binding ClearRouteCommand}" 
                            Background="{DynamicResource TextFillColorSecondaryBrush}" Style="{StaticResource ActionBtn}" Margin="0,0,4,0"/>
                    <Button Content="🔄" Command="{Binding RefreshCommand}" 
                            Background="{DynamicResource ThemePrimary}" Style="{StaticResource ActionBtn}"/>
                </StackPanel>
            </Border>
            
            <!-- === LİSTELER (Tab) === -->
            <TabControl Grid.Row="3" Background="Transparent" BorderThickness="0" Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="12,6"/>
                    </Style>
                </TabControl.Resources>
                
                <!-- ROTA TAB -->
                <TabItem Header="📋 Rota Sırası">
                    <Border Style="{StaticResource CardBorder}" Padding="4" Margin="0,4,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RoutePoints}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="2" CornerRadius="8" Padding="10,8" 
                                                Background="{Binding StatusBgColor}" 
                                                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Sıra Numarası -->
                                                <Border Grid.Column="0" Background="{DynamicResource ThemePrimary}" CornerRadius="15" 
                                                        Width="28" Height="28" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding OrderIndex}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                                                               FontWeight="Bold" FontSize="12" 
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                
                                                <!-- Bilgi -->
                                                <StackPanel Grid.Column="1" Margin="8,0,4,0">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" 
                                                               Foreground="{DynamicResource TextHeadingBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding CustomerName}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding StatusDisplay}" FontSize="10" 
                                                               Foreground="{Binding StatusColor}" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                
                                                <!-- Butonlar -->
                                                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                                    <Button Content="▲" FontSize="10" Padding="4,2" Margin="0,0,0,2"
                                                            Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" Cursor="Hand" Background="Transparent" BorderThickness="0"/>
                                                    <Button Content="✓" FontSize="12" Padding="4,2" Margin="0,0,0,2"
                                                            Command="{Binding DataContext.MarkVisitedCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" Cursor="Hand" Foreground="{DynamicResource ThemeSuccess}" Background="Transparent" BorderThickness="0"/>
                                                    <Button Content="▼" FontSize="10" Padding="4,2" Margin="0,0,0,2"
                                                            Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" Cursor="Hand" Background="Transparent" BorderThickness="0"/>
                                                    <Button Content="✕" FontSize="10" Padding="4,2" Foreground="{DynamicResource ThemeError}"
                                                            Command="{Binding DataContext.RemoveFromRouteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" Cursor="Hand" Background="Transparent" BorderThickness="0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </TabItem>
                
                <!-- PLANLANMIŞ İŞLER TAB -->
                <TabItem Header="📅 Planlanmış İşler">
                    <Border Style="{StaticResource CardBorder}" Padding="4" Margin="0,4,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding AvailableJobs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="2" CornerRadius="8" Padding="10,8" Background="{DynamicResource ThemeSurface}" 
                                                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding PriorityDisplay}" FontSize="11" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding CategoryDisplay}" FontSize="11"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" 
                                                               Foreground="{DynamicResource TextHeadingBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding CustomerName}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding Address}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                
                                                <Button Grid.Column="1" Content="➕" FontSize="16" Padding="8,4"
                                                        Command="{Binding DataContext.AddToRouteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" Cursor="Hand"
                                                        Background="Transparent" BorderThickness="0" 
                                                        Foreground="{DynamicResource ThemePrimary}" VerticalAlignment="Center"
                                                        ToolTip="Rotaya Ekle"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
        
        <!-- ============ SAĞ PANEL: HARİTA ============ -->
        <Border Grid.Column="1" CornerRadius="10" ClipToBounds="True" 
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.08" Color="Black"/>
            </Border.Effect>
            <Grid>
                <wv2:WebView2 x:Name="MapWebView"/>
                
                <!-- Yükleniyor -->
                <Border x:Name="LoadingOverlay" Background="{DynamicResource ThemeSurface}" CornerRadius="10" 
                        Visibility="Visible">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🗺️" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="Harita yükleniyor..." FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="3" Margin="0,15,0,0"
                                     Foreground="{DynamicResource ThemePrimary}" Background="{DynamicResource ThemePrimaryLight}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

