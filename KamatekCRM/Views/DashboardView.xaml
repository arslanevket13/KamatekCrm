<UserControl x:Class="KamatekCrm.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:km="clr-namespace:KamatekCrm.Components"
             mc:Ignorable="d"
             Background="{DynamicResource SurfacePageBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════ ROW 0: HEADER ═══════════════ -->
            <DockPanel Grid.Row="0" Margin="0,0,0,28">
                <!-- Right: Refresh -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Content="Yenile" 
                            Icon="{ui:SymbolIcon ArrowSync24}"
                            Command="{Binding RefreshDashboardCommand}"
                            Appearance="Secondary"
                            Height="40"/>
                </StackPanel>

                <!-- Left: Welcome -->
                <StackPanel>
                    <TextBlock Text="{Binding WelcomeMessage}" 
                               FontSize="30" FontWeight="Bold" 
                               Foreground="{DynamicResource TextHeadingBrush}"/>
                    <TextBlock FontSize="13" Margin="0,6,0,0"
                               Foreground="{DynamicResource TextMutedBrush}">
                        <Run Text="Komut Merkezi • "/>
                        <Run Text="{Binding TodayDate, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </DockPanel>

            <!-- ═══════════════ ROW 1: İŞ & OPERASYON KPI'LARI ═══════════════ -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">
                <km:KmKpiCard Title="Bugünün İşleri" 
                              Value="{Binding TodaysJobsCount}" 
                              Icon="📅"
                              Subtitle="planlanmış"
                              AccentBrush="{DynamicResource KpiGradientBlue}"
                              Margin="0,0,10,0"/>

                <km:KmKpiCard Title="Teslime Hazır" 
                              Value="{Binding ReadyRepairsCount}" 
                              Icon="✅"
                              Subtitle="cihaz bekliyor"
                              AccentBrush="{DynamicResource KpiGradientGreen}"
                              Margin="5,0,5,0"/>

                <km:KmKpiCard Title="Stok Uyarısı" 
                              Value="{Binding LowStockCount}" 
                              Icon="⚠️"
                              Subtitle="düşük stok"
                              AccentBrush="{DynamicResource KpiGradientRed}"
                              Margin="5,0,5,0"/>

                <km:KmKpiCard Title="Aktif İşler" 
                              Value="{Binding ActiveJobsCount}" 
                              Icon="🔧"
                              Subtitle="devam ediyor"
                              AccentBrush="{DynamicResource KpiGradientOrange}"
                              Margin="10,0,0,0"/>
            </UniformGrid>

            <!-- ═══════════════ ROW 2: SATIŞ & MÜŞTERİ KPI'LARI ═══════════════ -->
            <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,24">
                <km:KmKpiCard Title="Bugünkü Satış"
                              Value="{Binding TodaySalesTotal}"
                              Prefix="₺" Format="N0"
                              Icon="💰"
                              Subtitle="{Binding TodaySalesCountText}"
                              AccentBrush="{DynamicResource KpiGradientPurple}"
                              Margin="0,0,10,0"/>

                <km:KmKpiCard Title="Haftalık Satış"
                              Value="{Binding WeekSalesTotal}"
                              Prefix="₺" Format="N0"
                              Icon="📊"
                              Subtitle="son 7 gün"
                              AccentBrush="{DynamicResource KpiGradientCyan}"
                              Margin="5,0,5,0"/>

                <km:KmKpiCard Title="Aylık Satış"
                              Value="{Binding MonthlySalesTotal}"
                              Prefix="₺" Format="N0"
                              Icon="📈"
                              Subtitle="{Binding CurrentMonthName}"
                              AccentBrush="{DynamicResource KpiGradientGreen}"
                              Margin="5,0,5,0"/>

                <km:KmKpiCard Title="Toplam Müşteri"
                              Value="{Binding TotalCustomers}"
                              Icon="👥"
                              Subtitle="kayıtlı"
                              AccentBrush="{DynamicResource KpiGradientPurple}"
                              Margin="10,0,0,0"/>
            </UniformGrid>

            <!-- ═══════════════ ROW 3: CHARTS ═══════════════ -->
            <Grid Grid.Row="3" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Haftalık Performans Grafiği -->
                <Border Grid.Column="0" CornerRadius="14" Margin="0,0,12,0" Padding="20"
                        Background="{DynamicResource SurfaceCardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        Effect="{DynamicResource Elevation2}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ChartMultiple24" FontSize="20" 
                                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Haftalık Performans" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextHeadingBrush}"/>
                            </StackPanel>
                            <TextBlock Text="Son 7 günlük gelir ve tamamlanan iş trendi" FontSize="12" 
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <lvc:CartesianChart Grid.Row="1" 
                                            Series="{Binding WeeklyTrendSeries}"
                                            XAxes="{Binding WeeklyTrendXAxes}"
                                            YAxes="{Binding WeeklyTrendYAxes}"
                                            Height="220"
                                            TooltipPosition="Top"
                                            ZoomMode="X"/>
                    </Grid>
                </Border>

                <!-- İş Kategorileri Dağılımı -->
                <Border Grid.Column="1" CornerRadius="14" Margin="12,0,0,0" Padding="20"
                        Background="{DynamicResource SurfaceCardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        Effect="{DynamicResource Elevation2}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="DataPie24" FontSize="20" 
                                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Aktif İş Dağılımı" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextHeadingBrush}"/>
                            </StackPanel>
                            <TextBlock Text="Kategori bazlı" FontSize="12" 
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <lvc:PieChart Grid.Row="1" 
                                      Series="{Binding JobCategoryPieSeries}"
                                      Height="220"
                                      TooltipPosition="Top"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════════ ROW 4: MAIN WIDGETS ═══════════════ -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="0.7*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ WIDGET 1: KRİTİK UYARILAR ═══ -->
                <Border Grid.Column="0" CornerRadius="14" Margin="0,0,12,0" Padding="20"
                        Background="{DynamicResource SurfaceCardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        Effect="{DynamicResource Elevation2}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" CornerRadius="10" Padding="14" Margin="-16,-16,-16,16"
                                Background="{DynamicResource StatusErrorBg}"
                                BorderBrush="{DynamicResource StatusErrorFg}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Warning24" FontSize="22" 
                                               Foreground="{DynamicResource StatusErrorFg}" VerticalAlignment="Center"/>
                                <StackPanel Margin="12,0,0,0">
                                    <TextBlock Text="Kritik Uyarılar" FontSize="15" FontWeight="Bold" 
                                               Foreground="{DynamicResource StatusErrorFg}"/>
                                    <TextBlock Text="Stok seviyeleri" FontSize="11" 
                                               Foreground="{DynamicResource StatusErrorFg}" Opacity="0.7"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="350">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding LowStockProducts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12" Margin="0,0,0,8" CornerRadius="8"
                                                    Background="{DynamicResource HoverOverlayBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding ProductName}" 
                                                                   FontWeight="Medium" FontSize="13"
                                                                   Foreground="{DynamicResource TextHeadingBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                            <km:KmStatusBadge Status="{Binding UrgencyBadgeStatus}" 
                                                                              Text="{Binding UrgencyLevel}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" CornerRadius="8" Padding="14,8"
                                                            VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#EF4444"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CurrentStock}" Value="0">
                                                                        <Setter Property="Background" Value="#991B1B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding CurrentStock}" 
                                                                   FontWeight="Bold" FontSize="18"
                                                                   Foreground="White" HorizontalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty State using KmEmptyState -->
                                <km:KmEmptyState Icon="✅" Title="Stoklar Yeterli"
                                                 Message="Tüm ürünlerin stok seviyeleri normal."
                                                 Visibility="{Binding IsLowStockEmpty, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ═══ WIDGET 2: BUGÜNÜN İŞLERİ + TESLİME HAZIR ═══ -->
                <Border Grid.Column="1" CornerRadius="14" Margin="12,0,12,0" Padding="20"
                        Background="{DynamicResource SurfaceCardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        Effect="{DynamicResource Elevation2}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header: Bugünün İşleri -->
                        <Border Grid.Row="0" CornerRadius="10" Padding="14" Margin="-16,-16,-16,16"
                                Background="{DynamicResource StatusInfoBg}"
                                BorderBrush="{DynamicResource StatusInfoFg}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Wrench24" FontSize="22" 
                                               Foreground="{DynamicResource StatusInfoFg}" VerticalAlignment="Center"/>
                                <StackPanel Margin="12,0,0,0">
                                    <TextBlock Text="Bugünün İşleri" FontSize="15" FontWeight="Bold" 
                                               Foreground="{DynamicResource StatusInfoFg}"/>
                                    <TextBlock Text="Arıza &amp; Saha Operasyonları" FontSize="11" 
                                               Foreground="{DynamicResource StatusInfoFg}" Opacity="0.7"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Today's Jobs List -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="150">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding TodaysJobs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10" Margin="0,0,0,6" CornerRadius="8"
                                                    Background="{DynamicResource HoverOverlayBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="#3B82F6" 
                                                            CornerRadius="6" Padding="10,6" Margin="0,0,12,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ScheduledTime}" 
                                                                   FontWeight="Bold" FontSize="12"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding CustomerName}" 
                                                                   FontWeight="Medium" FontSize="13"
                                                                   Foreground="{DynamicResource TextHeadingBrush}"/>
                                                        <TextBlock Text="{Binding Category}" FontSize="11" 
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty State -->
                                <km:KmEmptyState Icon="📅" Title="İş Yok"
                                                 Message="Bugün planlanmış iş bulunmuyor."
                                                 Visibility="{Binding IsTodaysJobsEmpty, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Separator: Teslime Hazır -->
                        <Border Grid.Row="2" CornerRadius="10" Padding="14" Margin="-16,12,-16,12"
                                Background="{DynamicResource StatusSuccessBg}"
                                BorderBrush="{DynamicResource StatusSuccessFg}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="18" 
                                               Foreground="{DynamicResource StatusSuccessFg}" VerticalAlignment="Center"/>
                                <TextBlock Text="Teslime Hazır Tamirler" FontSize="13" FontWeight="Bold" 
                                           Foreground="{DynamicResource StatusSuccessFg}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Ready Repairs List -->
                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" MaxHeight="150">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding ReadyToDeliverRepairs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10" Margin="0,0,0,6" CornerRadius="8"
                                                    Background="{DynamicResource HoverOverlayBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="#10B981" 
                                                            CornerRadius="6" Padding="8,4" Margin="0,0,12,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TicketNo}" 
                                                                   FontWeight="Bold" FontSize="11"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding CustomerName}" 
                                                                   FontWeight="Medium" FontSize="13"
                                                                   Foreground="{DynamicResource TextHeadingBrush}"/>
                                                        <TextBlock Text="{Binding DeviceInfo}" FontSize="11" 
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <TextBlock FontSize="12" Foreground="{DynamicResource StatusWarningFg}" FontWeight="SemiBold">
                                                            <Run Text="{Binding DaysWaiting, Mode=OneWay}"/>
                                                            <Run Text=" gün"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty State -->
                                <km:KmEmptyState Icon="📦" Title="Teslime hazır cihaz yok"
                                                 Message="Bekleyen tamir bulunmuyor."
                                                 Visibility="{Binding IsReadyRepairsEmpty, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ═══ WIDGET 3: AYLIK ÖZET ═══ -->
                <Border Grid.Column="2" CornerRadius="14" Margin="12,0,0,0" Padding="20"
                        Background="{DynamicResource SurfaceCardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        Effect="{DynamicResource Elevation2}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" CornerRadius="10" Padding="14" Margin="-16,-16,-16,16"
                                Background="{DynamicResource StatusWarningBg}"
                                BorderBrush="{DynamicResource StatusWarningFg}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Money24" FontSize="22" 
                                               Foreground="{DynamicResource StatusWarningFg}" VerticalAlignment="Center"/>
                                <StackPanel Margin="12,0,0,0">
                                    <TextBlock Text="Aylık Özet" FontSize="15" FontWeight="Bold" 
                                               Foreground="{DynamicResource StatusWarningFg}"/>
                                    <TextBlock Text="{Binding CurrentMonthName}" FontSize="11" 
                                               Foreground="{DynamicResource StatusWarningFg}" Opacity="0.7"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Content -->
                        <StackPanel Grid.Row="1" VerticalAlignment="Top">
                            
                            <!-- Total Sales -->
                            <Border CornerRadius="14" Padding="20" Margin="0,0,0,16"
                                    Background="{DynamicResource HoverOverlayBrush}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="TOPLAM SATIŞ" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock FontSize="34" FontWeight="Bold" 
                                               Foreground="{DynamicResource StatusSuccessFg}" HorizontalAlignment="Center"
                                               Margin="0,8,0,0">
                                        <Run Text="₺"/>
                                        <Run Text="{Binding MonthlySalesTotal, StringFormat=N0, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center" Margin="0,6,0,0">
                                        <Run Text="{Binding MonthlySalesCount, Mode=OneWay}"/>
                                        <Run Text=" işlem"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Quick Stats -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Completed Jobs -->
                                <Border Grid.Column="0" CornerRadius="12" Padding="14" Margin="0,0,6,0"
                                        Background="{DynamicResource StatusSuccessBg}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="10" 
                                                           Foreground="{DynamicResource StatusSuccessFg}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Biten" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource StatusSuccessFg}" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding MonthlyJobsCompleted}" 
                                                   FontSize="28" FontWeight="Bold" 
                                                   Foreground="{DynamicResource StatusSuccessFg}" HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Active Jobs -->
                                <Border Grid.Column="1" CornerRadius="12" Padding="14" Margin="6,0,0,0"
                                        Background="{DynamicResource StatusWarningBg}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <ui:SymbolIcon Symbol="Timer24" FontSize="10" 
                                                           Foreground="{DynamicResource StatusWarningFg}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Aktif" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource StatusWarningFg}" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding ActiveJobsCount}" 
                                                   FontSize="28" FontWeight="Bold" 
                                                   Foreground="{DynamicResource StatusWarningFg}" HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Daily Summary -->
                            <Border CornerRadius="12" Padding="14" Margin="0,16,0,0"
                                    Background="{DynamicResource HoverOverlayBrush}">
                                <StackPanel>
                                    <TextBlock Text="BUGÜN" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock FontSize="14" Foreground="{DynamicResource StatusSuccessFg}" FontWeight="SemiBold">
                                            <Run Text="↑ ₺"/>
                                            <Run Text="{Binding DailyIncome, StringFormat=N0, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text=" / " FontSize="14" Foreground="{DynamicResource TextMutedBrush}"/>
                                        <TextBlock FontSize="14" Foreground="{DynamicResource StatusErrorFg}" FontWeight="SemiBold">
                                            <Run Text="↓ ₺"/>
                                            <Run Text="{Binding DailyExpense, StringFormat=N0, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
