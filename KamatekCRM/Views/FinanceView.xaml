<UserControl x:Class="KamatekCrm.Views.FinanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KamatekCrm.ViewModels"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="{DynamicResource ApplicationBackgroundBrush}">

    <UserControl.Resources>
        <!-- Kart Stili -->
        <Style x:Key="SummaryCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.15" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Büyük Tutar Stili -->
        <Style x:Key="BigAmount" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>

        <!-- Kart Başlığı -->
        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Summary Cards -->
            <RowDefinition Height="Auto"/>  <!-- Gider Ekleme -->
            <RowDefinition Height="*"/>     <!-- İşlem Listesi -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Money24" FontSize="28" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,12,0"/>
                    <TextBlock Text="KASA / FİNANS" 
                               FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
                <TextBlock Text="Günlük gelir-gider takibi ve kasa raporu" 
                           FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Tarih Kontrolleri -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="◀" Command="{Binding PreviousDayCommand}"
                        Width="32" Height="32" FontSize="14"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderThickness="0"
                        Margin="0,0,4,0" Cursor="Hand"/>
                
                <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}" 
                            Width="140" VerticalAlignment="Center"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderThickness="0"/>
                
                <Button Content="▶" Command="{Binding NextDayCommand}"
                        Width="32" Height="32" FontSize="14"
                        Background="{DynamicResource ThemePrimaryDark}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderThickness="0"
                        Margin="4,0,12,0" Cursor="Hand"/>

                <Button Content="📅 Bugün" Command="{Binding GoToTodayCommand}"
                        Padding="12,6" Background="{DynamicResource ThemePrimary}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,12,0"/>

                <CheckBox Content="Aylık Görünüm" 
                          IsChecked="{Binding ShowMonthly}" 
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- SUMMARY CARDS -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
            
            <!-- Nakit Gelir -->
            <Border Style="{StaticResource SummaryCard}" Background="{DynamicResource ThemeSuccessDark}">
                <StackPanel>
                    <TextBlock Text="NAKİT GELİR" Style="{StaticResource CardLabel}"/>
                    <TextBlock Text="{Binding CashIncome, StringFormat='₺{0:N2}'}" 
                               Style="{StaticResource BigAmount}"/>
                    <TextBlock Text="💵 Nakit Ödemeler" Foreground="{DynamicResource ThemeSuccessLight}" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Kredi Kartı Gelir -->
            <Border Style="{StaticResource SummaryCard}" Background="{DynamicResource ThemePrimaryDark}">
                <StackPanel>
                    <TextBlock Text="KREDİ KARTI" Style="{StaticResource CardLabel}"/>
                    <TextBlock Text="{Binding CardIncome, StringFormat='₺{0:N2}'}" 
                               Style="{StaticResource BigAmount}"/>
                    <TextBlock Text="💳 Kart Ödemeleri" Foreground="{DynamicResource ThemePrimaryLight}" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Giderler -->
            <Border Style="{StaticResource SummaryCard}" Background="{DynamicResource ThemeErrorDark}">
                <StackPanel>
                    <TextBlock Text="GİDERLER" Style="{StaticResource CardLabel}"/>
                    <TextBlock Text="{Binding TotalExpense, StringFormat='₺{0:N2}'}" 
                               Style="{StaticResource BigAmount}"/>
                    <TextBlock Text="📤 Masraflar" Foreground="{DynamicResource ThemeErrorLight}" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Net Kasa -->
            <Border Style="{StaticResource SummaryCard}" Background="{DynamicResource ThemeInfoDark}">
                <StackPanel>
                    <TextBlock Text="NET KASA" Style="{StaticResource CardLabel}"/>
                    <TextBlock Text="{Binding NetBalanceDisplay}" 
                               Style="{StaticResource BigAmount}"/>
                    <TextBlock Text="📊 Gün Sonu Bakiye" Foreground="{DynamicResource ThemeInfoLight}" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- GİDER EKLEME BÖLÜMÜ -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="➖ GİDER EKLE:" 
                           FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Tutar (₺)" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewExpenseAmount, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="Kategori" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding ExpenseCategories}"
                              SelectedItem="{Binding NewExpenseCategory}"
                              Padding="10,8" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock Text="Açıklama" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewExpenseDescription, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="14" 
                             ToolTip="Örn: Elektrik faturası, Malzeme alımı..."/>
                </StackPanel>

                <Button Grid.Column="4" Content="💾 KAYDET" 
                        Command="{Binding AddExpenseCommand}"
                        Padding="20,12" FontSize="14" FontWeight="Bold"
                        Background="{DynamicResource ThemeWarning}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderThickness="0"
                        VerticalAlignment="Bottom" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- İŞLEM LİSTESİ -->
        <Border Grid.Row="3" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Liste Header -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="📋 KASA HAREKETLERİ" 
                               FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Padding="10,8" Margin="0,0,8,0"
                                 Background="{DynamicResource SurfacePageBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{DynamicResource SurfacePageBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        
                        <Button Content="🔄" Command="{Binding RefreshCommand}"
                                Width="36" Height="36" FontSize="16"
                                Background="{DynamicResource ThemePrimaryDark}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderThickness="0"
                                ToolTip="Yenile" Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <!-- DataGrid -->
                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding FilteredTransactions}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          RowBackground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                          AlternatingRowBackground="{DynamicResource SurfacePageBrush}"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderDefaultBrush}"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          RowHeight="45"
                          VerticalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="False"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          CanUserAddRows="False">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource SurfacePageBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryLight}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ThemePrimary}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TARİH" Width="130"
                                            Binding="{Binding Date, StringFormat='dd.MM.yyyy HH:mm'}"/>

                        <DataGridTemplateColumn Header="TÜR" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsIncome}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource ThemeSuccessDark}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsExpense}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource ThemeErrorDark}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TransactionType}" Value="CashIncome">
                                                            <Setter Property="Text" Value="💵 NAKİT"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TransactionType}" Value="CardIncome">
                                                            <Setter Property="Text" Value="💳 KART"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TransactionType}" Value="Expense">
                                                            <Setter Property="Text" Value="📤 GİDER"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TransactionType}" Value="TransferIncome">
                                                            <Setter Property="Text" Value="🏦 HAVALE+"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TransactionType}" Value="TransferExpense">
                                                            <Setter Property="Text" Value="🏦 HAVALE-"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="KATEGORİ" Width="110"
                                            Binding="{Binding Category}"/>

                        <DataGridTextColumn Header="AÇIKLAMA" Width="*"
                                            Binding="{Binding Description}"/>

                        <DataGridTextColumn Header="MÜŞTERİ" Width="150"
                                            Binding="{Binding Customer.FullName}"/>

                        <DataGridTemplateColumn Header="TUTAR" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock FontWeight="Bold" FontSize="13" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Amount, StringFormat='₺{0:N2}'}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsIncome}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource StatusSuccessFg}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsExpense}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource StatusErrorFg}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑️" 
                                            Command="{Binding DataContext.DeleteTransactionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource ThemeError}" FontSize="14" Cursor="Hand"
                                            ToolTip="Sil (Sadece Admin)"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>


