<UserControl x:Class="KamatekCrm.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KamatekCrm.Views"
             xmlns:vm="clr-namespace:KamatekCrm.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="⚙️ AYARLAR" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextHeadingBrush}"/>
                <TextBlock Text="Uygulama yapılandırması ve veritabanı yönetimi" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <WrapPanel>
                <!-- Backup Card -->
                <Border Width="300" Margin="0,0,20,20" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                        BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Card Header -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource StatusSuccessBg}" CornerRadius="20" Width="40" Height="40" Margin="0,0,10,0">
                                <TextBlock Text="💾" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Veritabanı &amp; Yedekleme" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="Veri güvenliği" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>

                        <Separator Margin="0,0,0,15"/>

                        <!-- Info -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="SON YEDEKLEME" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding LastBackupText}" FontSize="16" FontWeight="SemiBold" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Backup Action -->
                        <Button Content="💾 ŞİMDİ YEDEK AL" 
                                Command="{Binding TakeBackupCommand}"
                                Background="{DynamicResource ThemeSuccess}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                FontWeight="Bold" Padding="15,10"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,0,10">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Restore Action -->
                        <Button Content="📂 YEDEKTEN YÜKLE" 
                                Command="{Binding RestoreBackupCommand}"
                                Background="{DynamicResource ThemeWarning}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                FontWeight="Bold" Padding="15,10"
                                BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock Text="* Uygulama kapanırken otomatik yedek alınır." 
                                   FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,10,0,0" 
                                   TextWrapping="Wrap" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <!-- Placeholder for future settings -->
                <Border Width="300" Margin="0,0,20,20" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                        BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" Padding="15" Opacity="0.5">
                    <StackPanel>
                        <TextBlock Text="👤 Kullanıcı Ayarları" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <TextBlock Text="Yakında eklenecek..." Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

