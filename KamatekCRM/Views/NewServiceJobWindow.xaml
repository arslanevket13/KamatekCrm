<Window x:Class="KamatekCrm.Views.NewServiceJobWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KamatekCrm.Views"
        xmlns:enums="clr-namespace:KamatekCrm.Shared.Enums;assembly=KamatekCrm.Shared"
        mc:Ignorable="d"
        Title="🔧 Profesyonel İş Emri Formu" 
        Width="1100" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfacePageBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Modern Card Style with Shadow -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Icon TextBlock Style -->
        <Style x:Key="FieldIcon" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemePrimary}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== TOP: MÜŞTERİ BİLGİ KARTI ========== -->
        <Border Grid.Row="0" Style="{StaticResource ModernCard}" Margin="16,16,16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Müşteri Seçimi -->
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="👤" Style="{StaticResource FieldIcon}"/>
                        <TextBlock Text="MÜŞTERİ SEÇİMİ" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource ThemePrimary}"/>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding Customers}"
                             SelectedItem="{Binding SelectedCustomer}"
                             DisplayMemberPath="FullName"
                             IsEditable="True"
                             IsTextSearchEnabled="True"
                             Background="{DynamicResource SurfacePageBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                             BorderBrush="{DynamicResource ThemePrimary}" BorderThickness="1"
                             TabIndex="0" Height="38" Padding="10,8"/>
                </StackPanel>
                
                <Border Grid.Column="1" Width="1" Background="{DynamicResource BorderDefaultBrush}" Margin="20,0"/>
                
                <!-- Öncelik ve Tarih -->
                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="🚨" Style="{StaticResource FieldIcon}"/>
                            <TextBlock Text="ÖNCELİK" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource ThemeError}"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding Priorities}"
                                 SelectedItem="{Binding SelectedPriority}"
                                 Background="{DynamicResource SurfacePageBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 BorderBrush="{DynamicResource ThemeError}" BorderThickness="1"
                                 TabIndex="1" Height="38" Padding="10,8">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Static enums:JobPriority.Low}">
                                                        <Setter Property="Text" Value="🟢 Düşük"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Static enums:JobPriority.Normal}">
                                                        <Setter Property="Text" Value="🔵 Normal"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Static enums:JobPriority.Urgent}">
                                                        <Setter Property="Text" Value="🟠 Acil"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Static enums:JobPriority.Critical}">
                                                        <Setter Property="Text" Value="🔴 Kritik"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📅" Style="{StaticResource FieldIcon}"/>
                            <TextBlock Text="PLANLANAN" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource ThemeSuccess}"/>
                        </StackPanel>
                        <DatePicker SelectedDate="{Binding ScheduledDate}" 
                                   Background="{DynamicResource SurfacePageBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   BorderBrush="{DynamicResource ThemeSuccess}" BorderThickness="1"
                                   Height="38" TabIndex="2"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ========== MAIN CONTENT: 2-COLUMN SPLIT ========== -->
        <Grid Grid.Row="1" Margin="16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT PANEL: İŞ VE YAPI BİLGİLERİ ===== -->
            <Border Grid.Column="0" Style="{StaticResource ModernCard}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="🏗️" FontSize="20" Margin="0,0,10,0"/>
                            <TextBlock Text="YAPI VE İŞ DETAYLARI" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>

                        <!-- Yapı Türü Seçimi -->
                        <Border Background="{DynamicResource SurfacePageBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="🏠" Style="{StaticResource FieldIcon}"/>
                                    <TextBlock Text="YAPI TÜRÜ" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ThemeInfo}"/>
                                </StackPanel>
                                
                                <ComboBox ItemsSource="{Binding StructureTypes}"
                                         SelectedItem="{Binding SelectedStructureType}"
                                         Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                         BorderBrush="{DynamicResource ThemeInfo}" BorderThickness="1"
                                         TabIndex="3" Height="36" Padding="10,8">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding}" Value="{x:Static enums:StructureType.SingleUnit}">
                                                                <Setter Property="Text" Value="🏠 Müstakil (Villa/Dükkan)"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="{x:Static enums:StructureType.Apartment}">
                                                                <Setter Property="Text" Value="🏢 Apartman"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="{x:Static enums:StructureType.Site}">
                                                                <Setter Property="Text" Value="🏘️ Site (Çoklu Blok)"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="{x:Static enums:StructureType.Commercial}">
                                                                <Setter Property="Text" Value="🏭 İşyeri/Fabrika"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <!-- Dynamic Fields -->
                                <Grid Visibility="{Binding ShowBlockCount, Converter={StaticResource BoolToVis}}" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Blok Sayısı" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding BlockCount, UpdateSourceTrigger=PropertyChanged}" 
                                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                TabIndex="4" Height="32" Padding="8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" Visibility="{Binding ShowFlatCount, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Daire Sayısı" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding FlatCount, UpdateSourceTrigger=PropertyChanged}" 
                                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                TabIndex="5" Height="32" Padding="8"/>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- Total Units Badge -->
                                <Border Background="{DynamicResource ThemePrimary}" CornerRadius="4" Padding="10,6" Margin="0,12,0,0" 
                                        HorizontalAlignment="Left"
                                        Visibility="{Binding ShowFlatCount, Converter={StaticResource BoolToVis}}">
                                    <TextBlock>
                                        <Run Text="Toplam: " Foreground="{DynamicResource ThemePrimaryLight}"/>
                                        <Run Text="{Binding TotalUnitCount, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <Run Text=" birim" Foreground="{DynamicResource ThemePrimaryLight}"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- KATEGORİ SEÇİMİ -->
                        <Border Background="{DynamicResource SurfaceCardBrushAlt}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="📂" Style="{StaticResource FieldIcon}"/>
                                    <TextBlock Text="İŞ KATEGORİLERİ" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ThemeWarning}"/>
                                </StackPanel>
                                
                                <ItemsControl ItemsSource="{Binding CategoryItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding DisplayName}"
                                                     IsChecked="{Binding IsSelected}"
                                                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                     Margin="0,4,16,4" FontSize="12"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- AÇIKLAMA -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="📝" Style="{StaticResource FieldIcon}"/>
                                <TextBlock Text="İŞ AÇIKLAMASI / TEKNİK NOTLAR" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ThemeSuccess}"/>
                            </StackPanel>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                    Background="{DynamicResource SurfacePageBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" 
                                    BorderBrush="{DynamicResource ThemeSuccess}" BorderThickness="1"
                                    TabIndex="6" Height="120"
                                    TextWrapping="Wrap" AcceptsReturn="True"
                                    VerticalScrollBarVisibility="Auto" Padding="12"/>
                            <TextBlock Text="💡 Kamera sayısı, dedektör adedi, kablo metrajı gibi teknik detayları yazın." 
                                      FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ===== RIGHT PANEL: MALZEME VE MALİYET ===== -->
            <Border Grid.Column="2" Style="{StaticResource ModernCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="📦" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="MALZEME VE MALİYET" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>

                    <!-- Ürün Ekleme -->
                    <Border Grid.Row="1" Background="{DynamicResource SurfacePageBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <ComboBox ItemsSource="{Binding Products}"
                                     SelectedItem="{Binding SelectedProductToAdd}"
                                     DisplayMemberPath="ProductName"
                                     IsEditable="True" IsTextSearchEnabled="True"
                                     Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                     BorderBrush="{DynamicResource ThemePrimary}" BorderThickness="1"
                                     TabIndex="7" Height="36" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                        Text="{Binding QuantityToAdd, UpdateSourceTrigger=PropertyChanged}"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        TabIndex="8" Height="32" Padding="8"/>
                                <TextBox Grid.Column="2"
                                        Text="{Binding UnitPriceToAdd, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        TabIndex="9" Height="32" Padding="8"/>
                                <Button Grid.Column="4" Content="➕" 
                                       Command="{Binding AddItemToJobCommand}"
                                       Background="{DynamicResource ThemeSuccess}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderThickness="0"
                                       TabIndex="10" Width="40" Height="32" Cursor="Hand"/>
                            </Grid>
                            
                            <CheckBox Content="🔄 Tüm birimlere uygula" 
                                     IsChecked="{Binding ApplyToAllUnits}"
                                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" Margin="0,10,0,0"
                                     TabIndex="11"/>
                        </StackPanel>
                    </Border>

                    <!-- Malzeme Listesi -->
                    <DataGrid Grid.Row="2"
                             ItemsSource="{Binding CurrentJobItems}"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             Background="{DynamicResource SurfacePageBrush}"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                             RowBackground="{DynamicResource SurfacePageBrush}"
                             AlternatingRowBackground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                             GridLinesVisibility="Horizontal"
                             HeadersVisibility="Column"
                             TabIndex="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ürün" Binding="{Binding Product.ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Adet" Binding="{Binding QuantityUsed}" Width="50"/>
                            <DataGridTextColumn Header="Fiyat" Binding="{Binding UnitPrice, StringFormat=₺{0:N0}}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Maliyet Özeti -->
                    <Border Grid.Row="3" Background="{DynamicResource SurfacePageBrush}" CornerRadius="8" Padding="15" Margin="0,12,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Malzeme:" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
                                <TextBlock Text="{Binding MaterialTotal, StringFormat=₺{0:N2}}" 
                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="İşçilik:" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
                                <TextBox Text="{Binding LaborCost, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                        Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextFillColorPrimaryBrush}" 
                                        FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right"
                                        Width="80" TextAlignment="Right" TabIndex="13"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="İndirim:" Foreground="{DynamicResource ThemeError}" FontSize="13"/>
                                <TextBox Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                        Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ThemeError}" 
                                        FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right"
                                        Width="80" TextAlignment="Right" TabIndex="14"/>
                            </Grid>
                            <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                                <Grid>
                                    <TextBlock Text="TOPLAM:" Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontSize="15" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding GrandTotal, StringFormat=₺{0:N2}}" 
                                              Foreground="{DynamicResource ThemeSuccess}" FontWeight="Bold" FontSize="22" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== FOOTER: ACTIONS ========== -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Padding="20,15">
            <Grid>
                <Button Content="❌ İptal" 
                       Command="{Binding CancelCommand}"
                       Background="{DynamicResource ThemeError}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderThickness="0"
                       IsCancel="True" TabIndex="16"
                       HorizontalAlignment="Left"
                       Width="100" Height="40" Cursor="Hand" FontSize="13"/>

                <Button Content="💾 İŞ EMRİNİ KAYDET" 
                       Command="{Binding SaveServiceJobCommand}"
                       Background="{DynamicResource ThemeSuccess}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" BorderThickness="0"
                       IsDefault="True" TabIndex="15"
                       HorizontalAlignment="Right"
                       Width="180" Height="40" Cursor="Hand"
                       FontSize="14" FontWeight="Bold"/>
            </Grid>
        </Border>
    </Grid>
</Window>


