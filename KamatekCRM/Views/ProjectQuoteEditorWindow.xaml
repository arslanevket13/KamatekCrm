<Window x:Class="KamatekCrm.Views.ProjectQuoteEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dd="urn:gong-wpf-dragdrop"
        Title="🏗️ PROJE TEKLİF EDİTÖRÜ" 
        Height="800" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    
    <Window.Resources>
        <!-- TreeView Item Template -->
        <HierarchicalDataTemplate x:Key="TreeNodeTemplate" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2">
                <TextBlock Text="{Binding HeaderDisplay}" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </HierarchicalDataTemplate>
        
        <!-- Product List Template -->
        <DataTemplate x:Key="ProductTemplate">
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="10,8" Margin="2"
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" Cursor="Hand">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SKU}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding SalePrice, StringFormat='₺{0:N0}'}" 
                               FontWeight="Bold" Foreground="{DynamicResource ThemeSuccess}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePrimary}" CornerRadius="8" Padding="20,15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🏗️ PROJE TEKLİF EDİTÖRÜ" 
                               FontSize="22" FontWeight="Bold" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                    <TextBlock Text="Profesyonel Mühendislik Tezgahı - Yapı Ağacı, Mahal Listesi, Ürün Kataloğu" 
                               FontSize="12" Foreground="{DynamicResource StatusInfoBg}" Margin="0,5,0,0"/>
                </StackPanel>
                
                <!-- Proje Kodu -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentProject.ProjectCode}" FontSize="16" 
                               FontWeight="Bold" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}" Margin="0,0,20,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Proje Bilgileri Bar -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="6" Padding="15" Margin="0,0,0,10"
                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Müşteri -->
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="MÜŞTERİ" FontWeight="SemiBold" FontSize="10" 
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Customers}"
                              SelectedItem="{Binding SelectedCustomer}"
                              DisplayMemberPath="FullName"
                              Height="32"/>
                </StackPanel>
                
                <!-- Proje Adı -->
                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="PROJE ADI" FontWeight="SemiBold" FontSize="10" 
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                             Height="32" Padding="8,6"/>
                </StackPanel>
                
                <!-- Yapı Oluşturucu -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Blok" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBox Text="{Binding BlockCount}" Width="50" Height="32" 
                                 TextAlignment="Center" Padding="5"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Kat" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBox Text="{Binding FloorCount}" Width="50" Height="32" 
                                 TextAlignment="Center" Padding="5"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Daire/Kat" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBox Text="{Binding FlatsPerFloor}" Width="50" Height="32" 
                                 TextAlignment="Center" Padding="5"/>
                    </StackPanel>
                    <Button Content="🏗️ YAPI OLUŞTUR" Command="{Binding GenerateStructureCommand}"
                            Background="{DynamicResource ThemeWarning}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}" FontWeight="SemiBold"
                            Padding="15,8" BorderThickness="0" Height="32" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Ana İçerik (3 Panel) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="300" MinWidth="250"/>
            </Grid.ColumnDefinitions>
            
            <!-- SOL PANEL: Yapı Ağacı -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" 
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Başlık -->
                    <Border Grid.Row="0" Background="{DynamicResource StatusInfoBg}" Padding="12,10">
                        <TextBlock Text="📍 YAPI AĞACI" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource ThemePrimary}"/>
                    </Border>
                    
                    <!-- TreeView -->
                    <TreeView Grid.Row="1" ItemsSource="{Binding RootNodes}"
                              ItemTemplate="{StaticResource TreeNodeTemplate}"
                              BorderThickness="0" Padding="5"
                              SelectedItemChanged="TreeView_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                <Setter Property="Padding" Value="3"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        
                        <!-- Context Menu -->
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="➕ Blok Ekle" Command="{Binding AddBlockCommand}"/>
                                <MenuItem Header="📋 Kat Ekle" Command="{Binding AddFloorCommand}"/>
                                <MenuItem Header="🏠 Daire Ekle" Command="{Binding AddFlatCommand}"/>
                                <MenuItem Header="🏭 Bölge Ekle" Command="{Binding AddZoneCommand}"/>
                                <Separator/>
                                <MenuItem Header="📑 Kopyala (Duplicate)" Command="{Binding DuplicateNodeCommand}"/>
                                <MenuItem Header="📝 Yeniden Adlandır / Etiketle" Command="{Binding RenameNodeCommand}"/>
                                <MenuItem Header="📋 Kardeşlere Uygula" Command="{Binding ApplyToSiblingsCommand}"/>
                                <Separator/>
                                <MenuItem Header="🗑️ Sil" Command="{Binding RemoveNodeCommand}" Foreground="{DynamicResource ThemeError}"/>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                    </TreeView>
                    
                    <!-- Tree Butonları -->
                    <Border Grid.Row="2" Background="{DynamicResource ThemeSurface}" Padding="8" 
                            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                        <WrapPanel>
                            <Button Content="➕ Blok" Command="{Binding AddBlockCommand}"
                                    Margin="2" Padding="8,4" FontSize="11"/>
                            <Button Content="📋 Kat" Command="{Binding AddFloorCommand}"
                                    Margin="2" Padding="8,4" FontSize="11"/>
                            <Button Content="🏠 Daire" Command="{Binding AddFlatCommand}"
                                    Margin="2" Padding="8,4" FontSize="11"/>
                        </WrapPanel>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" 
                          Background="Transparent" Cursor="SizeWE"/>
            
            <!-- ORTA PANEL: Mahal Listesi -->
            <Border Grid.Column="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" 
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                    dd:DragDrop.IsDropTarget="True"
                    dd:DragDrop.DropHandler="{Binding}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Başlık -->
                    <Border Grid.Row="0" Background="{DynamicResource StatusSuccessBg}" Padding="12,10">
                        <Grid>
                            <TextBlock Text="{Binding SelectedNodeName, StringFormat='🛠️ {0} - Kalem Listesi'}" 
                                       FontWeight="Bold" FontSize="13" Foreground="{DynamicResource ThemeSuccess}"/>
                            <TextBlock Text="{Binding SelectedNodeSubTotal, StringFormat='₺{0:N0}'}" 
                                       HorizontalAlignment="Right" FontWeight="Bold" 
                                       FontSize="14" Foreground="{DynamicResource ThemeSuccess}"/>
                        </Grid>
                    </Border>
                    
                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding CurrentNodeItems}"
                              SelectedItem="{Binding SelectedItem}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ürün" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Adet" Binding="{Binding Quantity}" Width="60"/>
                            <DataGridTextColumn Header="Alış ₺" Binding="{Binding UnitCost, StringFormat='{}{0:N0}'}" Width="80">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Satış ₺" Binding="{Binding UnitPrice, StringFormat='{}{0:N0}'}" Width="80"/>
                            <DataGridTextColumn Header="İşçilik ₺" Binding="{Binding LaborCost, StringFormat='{}{0:N0}'}" Width="80"/>
                            <DataGridTextColumn Header="Toplam ₺" Binding="{Binding TotalPrice, StringFormat='{}{0:N0}'}" Width="90" IsReadOnly="True">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Marj" Binding="{Binding MarginDisplay}" Width="60" IsReadOnly="True"/>
                            <DataGridCheckBoxColumn Header="Ops." Binding="{Binding IsOptional}" Width="40"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Alt Bar -->
                    <Border Grid.Row="2" Background="{DynamicResource ThemeSurface}" Padding="10" 
                            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                        <Grid>
                            <Button Content="🗑️ Kalemi Sil" Command="{Binding RemoveItemCommand}"
                                    Background="{DynamicResource ThemeError}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                                    Padding="12,6" BorderThickness="0" HorizontalAlignment="Left"/>
                            
                            <TextBlock Text="💡 Sağ panelden ürün sürükleyip bırakın" 
                                       FontSize="11" Foreground="{DynamicResource ThemeMuted}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" 
                          Background="Transparent" Cursor="SizeWE"/>
            
            <!-- SAĞ PANEL: Ürün Kataloğu -->
            <Border Grid.Column="4" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" 
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Başlık -->
                    <Border Grid.Row="0" Background="{DynamicResource ThemeWarningBg}" Padding="12,10">
                        <TextBlock Text="📦 ÜRÜN &amp; HİZMET KATALOĞU" FontWeight="Bold" 
                                   FontSize="13" Foreground="{DynamicResource ThemeWarning}"/>
                    </Border>
                    
                    <!-- Arama -->
                    <Border Grid.Row="1" Padding="10,8">
                        <TextBox Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32" Padding="30,6,8,6"/>
                    </Border>
                    
                    <!-- Ürün Listesi -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding FilteredProducts}"
                             SelectedItem="{Binding SelectedProduct}"
                             ItemTemplate="{StaticResource ProductTemplate}"
                             BorderThickness="0" Padding="5"
                             dd:DragDrop.IsDragSource="True"
                             dd:DragDrop.DragAdornerTemplate="{StaticResource ProductTemplate}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                    
                    <!-- Ekle Butonu -->
                    <Border Grid.Row="3" Background="{DynamicResource ThemeSurface}" Padding="10" 
                            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                        <Button Content="➕ SEÇİLİ NODE'A EKLE" Command="{Binding AddItemCommand}"
                                Background="{DynamicResource ThemeSuccess}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}" FontWeight="SemiBold"
                                Padding="10,8" BorderThickness="0" Cursor="Hand"
                                HorizontalAlignment="Stretch"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Footer: Finansal Özet ve Butonlar -->
        <Border Grid.Row="3" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="15" Margin="0,10,0,0"
                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Üst Satır: Finansal -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <!-- Maliyet -->
                    <Border Background="{DynamicResource StatusErrorBg}" CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="MALİYET" FontSize="9" Foreground="{DynamicResource ThemeError}"/>
                            <TextBlock Text="{Binding TotalCostDisplay}" FontSize="15" 
                                       FontWeight="Bold" Foreground="{DynamicResource ThemeError}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Satış -->
                    <Border Background="{DynamicResource StatusInfoBg}" CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="SATIŞ" FontSize="9" Foreground="{DynamicResource ThemePrimary}"/>
                            <TextBlock Text="{Binding TotalRevenueDisplay}" FontSize="15" 
                                       FontWeight="Bold" Foreground="{DynamicResource ThemePrimary}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- İskonto -->
                    <Border Background="{DynamicResource ThemeWarningBg}" CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="İSKONTO %" FontSize="9" Foreground="{DynamicResource ThemeWarning}" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="40" Height="18" FontSize="10" TextAlignment="Center" 
                                         Padding="2,1" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding DiscountAmountDisplay}" FontSize="14" 
                                       FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- KDV -->
                    <Border Background="{DynamicResource ThemeInfoLight}" CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="KDV %" FontSize="9" Foreground="{DynamicResource ThemeInfo}" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding KdvRate, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="40" Height="18" FontSize="10" TextAlignment="Center" 
                                         Padding="2,1" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding KdvAmountDisplay}" FontSize="14" 
                                       FontWeight="Bold" Foreground="{DynamicResource ThemeInfo}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Genel Toplam -->
                    <Border Background="{DynamicResource StatusSuccessBg}" CornerRadius="6" Padding="12,8" Margin="0,0,8,0"
                            BorderBrush="{DynamicResource ThemeSuccess}" BorderThickness="2">
                        <StackPanel>
                            <TextBlock Text="GENEL TOPLAM" FontSize="9" Foreground="{DynamicResource ThemeSuccess}"/>
                            <TextBlock Text="{Binding GrandTotalDisplay}" FontSize="18" 
                                       FontWeight="Bold" Foreground="{DynamicResource ThemeSuccess}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Kar -->
                    <Border Background="{DynamicResource StatusSuccessBg}" CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="KAR" FontSize="9" Foreground="{DynamicResource ThemeSuccess}"/>
                            <TextBlock Text="{Binding TotalProfitDisplay}" FontSize="15" 
                                       FontWeight="Bold" Foreground="{DynamicResource ThemeSuccess}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Marj -->
                    <Border Background="{DynamicResource ThemeWarningBg}" CornerRadius="6" Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="MARJ" FontSize="9" Foreground="{DynamicResource ThemeWarning}"/>
                            <TextBlock Text="{Binding OverallMarginDisplay}" FontSize="15" 
                                       FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Alt Satır: Butonlar + Durum -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Durum Bilgisi -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{DynamicResource StatusInfoBg}" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding QuoteStatusDisplay, StringFormat='Durum: {0}'}" 
                                       FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemePrimary}"/>
                        </Border>
                        <Border Background="{DynamicResource ThemeInfoLight}" CornerRadius="4" Padding="8,4">
                            <TextBlock Text="{Binding RevisionDisplay}" 
                                       FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeInfo}"/>
                        </Border>
                    </StackPanel>
                    
                    <!-- Butonlar -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="❌ İPTAL" 
                                Command="{Binding CancelCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                Background="{DynamicResource ThemeMuted}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                FontWeight="SemiBold" Padding="20,10"
                                Margin="0,0,8,0" BorderThickness="0" Cursor="Hand"/>
                        
                        <Button Content="📝 PDF DIŞA AKTAR" 
                                Command="{Binding ExportPdfCommand}"
                                Background="{DynamicResource ThemeWarning}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                FontWeight="SemiBold" Padding="20,10"
                                Margin="0,0,8,0" BorderThickness="0" Cursor="Hand"/>

                        <Button Content="📧 E-POSTA GÖNDER" 
                                Command="{Binding SendEmailCommand}"
                                Background="{DynamicResource ThemePrimary}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                FontWeight="SemiBold" Padding="20,10"
                                Margin="0,0,8,0" BorderThickness="0" Cursor="Hand"/>

                        <Button Content="💾 KAYDET" 
                                Command="{Binding SaveCommand}"
                                Background="{DynamicResource ThemeSuccess}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                FontWeight="Bold" FontSize="14" Padding="30,10"
                                BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

