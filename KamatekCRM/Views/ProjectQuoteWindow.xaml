<Window x:Class="KamatekCrm.Views.ProjectQuoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🏗️ PROJE &amp; TEKLİF OLUŞTUR" 
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePrimary}" CornerRadius="8" Padding="20,15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="🏗️ PROJE &amp; TEKLİF OLUŞTUR" 
                           FontSize="22" FontWeight="Bold" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                <TextBlock Text="Müşteri seçin, yapı tanımlayın ve teklif hazırlayın" 
                           FontSize="12" Foreground="{DynamicResource StatusInfoBg}" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- TabControl -->
        <TabControl Grid.Row="1" Margin="0,0,0,15">
            
            <!-- TAB 1: Keşif & Yapı -->
            <TabItem Header="📋 KEŞİF &amp; YAPI" Padding="15,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        
                        <!-- Müşteri Seçimi -->
                        <TextBlock Text="MÜŞTERİ" FontWeight="SemiBold" FontSize="12" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding Customers}"
                                  SelectedItem="{Binding SelectedCustomer}"
                                  DisplayMemberPath="FullName"
                                  Height="40" FontSize="14"/>
                        
                        <!-- Proje Adı -->
                        <TextBlock Text="PROJE ADI" FontWeight="SemiBold" FontSize="12" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,20,0,8"/>
                        <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                                 Height="40" FontSize="14" Padding="10,8"/>
                        
                        <!-- Yapı Tanımı -->
                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" Margin="0,25,0,0"
                                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="🏢 YAPI TANIMI" FontWeight="Bold" FontSize="14" 
                                           Foreground="{DynamicResource ThemePrimary}" Margin="0,0,0,15"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Blok Sayısı -->
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Blok Sayısı" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Text="{Binding BlockCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="45" FontSize="18" TextAlignment="Center"
                                                 FontWeight="SemiBold" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Kat Sayısı -->
                                    <StackPanel Grid.Column="1" Margin="5,0">
                                        <TextBlock Text="Kat Sayısı" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Text="{Binding FloorCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="45" FontSize="18" TextAlignment="Center"
                                                 FontWeight="SemiBold" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Daire/Kat -->
                                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                        <TextBlock Text="Daire / Kat" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Text="{Binding FlatsPerFloor, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="45" FontSize="18" TextAlignment="Center"
                                                 FontWeight="SemiBold" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- Toplam Birim -->
                                <Border Background="{DynamicResource StatusInfoBg}" CornerRadius="6" Padding="15,12" Margin="0,20,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="📊 TOPLAM BİRİM: " FontSize="16" 
                                                   FontWeight="SemiBold" Foreground="{DynamicResource ThemePrimary}"/>
                                        <TextBlock Text="{Binding TotalUnitCount}" FontSize="24" 
                                                   FontWeight="Bold" Foreground="{DynamicResource ThemePrimary}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- TAB 2: Teklif Hazırla -->
            <TabItem Header="💰 TEKLİF HAZIRLA" Padding="15,8">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Sol: Ürün Kataloğu -->
                    <Border Grid.Column="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" 
                            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="📦 ÜRÜN KATALOĞU" 
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="{DynamicResource ThemePrimary}" Margin="15,12"/>
                            
                            <ListBox Grid.Row="1" ItemsSource="{Binding Products}"
                                     SelectedItem="{Binding SelectedProduct}"
                                     BorderThickness="0" Margin="10,0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5,8">
                                            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SalePrice, StringFormat='{}{0:C}'}" 
                                                       FontSize="11" Foreground="{DynamicResource ThemeSuccess}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            
                            <!-- Ekle Butonu -->
                            <Border Grid.Row="2" Padding="10" Background="{DynamicResource ThemeSurface}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Adet/Birim:" VerticalAlignment="Center" 
                                                   FontSize="12" Margin="0,0,10,0"/>
                                        <TextBox Text="{Binding QtyPerUnit, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="60" Height="30" TextAlignment="Center"/>
                                    </StackPanel>
                                    <Button Content="➕ TEKLİFE EKLE" 
                                            Command="{Binding AddToQuoteCommand}"
                                            Background="{DynamicResource ThemeSuccess}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            FontWeight="SemiBold" Height="35"
                                            BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- Sağ: Teklif Kalemleri -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="📋 TEKLİF KALEMLERİ" 
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="{DynamicResource ThemePrimary}" Margin="15,12"/>
                            
                            <DataGrid Grid.Row="1" ItemsSource="{Binding QuoteItems}"
                                      SelectedItem="{Binding SelectedQuoteItem}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ürün" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding UnitPrice, StringFormat='{}{0:C}'}" Width="100"/>
                                    <DataGridTextColumn Header="Adet/Birim" Binding="{Binding QtyPerUnit}" Width="80"/>
                                    <DataGridTextColumn Header="Toplam Adet" Binding="{Binding TotalQuantity}" Width="90"/>
                                    <DataGridTextColumn Header="Toplam" Binding="{Binding TotalPrice, StringFormat='{}{0:C}'}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            
                            <!-- Alt: Toplam ve Kaldır -->
                            <Border Grid.Row="2" Background="{DynamicResource ThemeSurface}" Padding="15"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Button Grid.Column="0" Content="🗑️ Kaldır"
                                            Command="{Binding RemoveFromQuoteCommand}"
                                            Background="{DynamicResource ThemeError}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            Padding="15,8" BorderThickness="0"/>
                                    
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="GENEL TOPLAM: " FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:C}'}" 
                                                   FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ThemeSuccess}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="❌ İPTAL" 
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="{DynamicResource ThemeMuted}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    FontWeight="SemiBold" Padding="25,12"
                    Margin="0,0,10,0" BorderThickness="0" Cursor="Hand"/>
            
            <Button Content="💾 KAYDET" 
                    Command="{Binding SaveCommand}"
                    Background="{DynamicResource ThemeSuccess}" Foreground="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    FontWeight="Bold" FontSize="14" Padding="30,12"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>

