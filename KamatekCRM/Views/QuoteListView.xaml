<UserControl x:Class="KamatekCrm.Views.QuoteListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:KamatekCrm.Converters"
             Background="{DynamicResource ThemeBackground}">
    
    <UserControl.Resources>
        <converters:QuoteStatusTextConverter x:Key="StatusTextConverter"/>
        <converters:QuoteStatusColorConverter x:Key="StatusColorConverter"/>
        <converters:DateDisplayConverter x:Key="DateConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- ═════════ HEADER ═════════ -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="10" 
                Padding="24,18" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📋 TEKLİF YÖNETİMİ" FontSize="24" FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="Tüm teklifleri görüntüleyin, yönetin ve takip edin" 
                               FontSize="12" Foreground="#CCE3F2FD" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="＋ YENİ TEKLİF" 
                        Command="{Binding NewQuoteCommand}"
                        Background="#4CAF50" Foreground="White" FontWeight="Bold"
                        FontSize="14" Padding="24,12" BorderThickness="0" 
                        Cursor="Hand" VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
        
        <!-- ═════════ KPI CARDS ═════════ -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Toplam -->
            <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="8" 
                    Padding="16,14" Margin="0,0,8,0" Cursor="Hand"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding FilterAllCommand}"/>
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="TOPLAM" FontSize="10" FontWeight="SemiBold" 
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Text="{Binding TotalQuoteCount}" FontSize="28" FontWeight="Bold" 
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="teklif" FontSize="11" 
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
            </Border>

            <!-- Taslak -->
            <Border Grid.Column="1" Background="{DynamicResource CardBrush}" CornerRadius="8" 
                    Padding="16,14" Margin="4,0" Cursor="Hand"
                    BorderBrush="#9E9E9E" BorderThickness="0,0,0,3">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding FilterDraftCommand}"/>
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="📝 TASLAK" FontSize="10" FontWeight="SemiBold" Foreground="#9E9E9E"/>
                    <TextBlock Text="{Binding DraftCount}" FontSize="28" FontWeight="Bold" 
                               Foreground="#9E9E9E" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Gönderildi -->
            <Border Grid.Column="2" Background="{DynamicResource CardBrush}" CornerRadius="8" 
                    Padding="16,14" Margin="4,0" Cursor="Hand"
                    BorderBrush="#2196F3" BorderThickness="0,0,0,3">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding FilterSentCommand}"/>
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="📨 GÖNDERİLDİ" FontSize="10" FontWeight="SemiBold" 
                               Foreground="#2196F3"/>
                    <TextBlock Text="{Binding SentCount}" FontSize="28" FontWeight="Bold" 
                               Foreground="#2196F3" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding TotalPendingAmountDisplay}" FontSize="11" 
                               Foreground="#2196F3"/>
                </StackPanel>
            </Border>

            <!-- Onaylandı -->
            <Border Grid.Column="3" Background="{DynamicResource CardBrush}" CornerRadius="8" 
                    Padding="16,14" Margin="4,0" Cursor="Hand"
                    BorderBrush="#4CAF50" BorderThickness="0,0,0,3">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding FilterApprovedCommand}"/>
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="✅ ONAYLANDI" FontSize="10" FontWeight="SemiBold" 
                               Foreground="#4CAF50"/>
                    <TextBlock Text="{Binding ApprovedCount}" FontSize="28" FontWeight="Bold" 
                               Foreground="#4CAF50" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding TotalApprovedAmountDisplay}" FontSize="11" 
                               Foreground="#4CAF50"/>
                </StackPanel>
            </Border>

            <!-- Reddedildi -->
            <Border Grid.Column="4" Background="{DynamicResource CardBrush}" CornerRadius="8" 
                    Padding="16,14" Margin="8,0,0,0" Cursor="Hand"
                    BorderBrush="#F44336" BorderThickness="0,0,0,3">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding FilterRejectedCommand}"/>
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="❌ REDDEDİLDİ" FontSize="10" FontWeight="SemiBold" 
                               Foreground="#F44336"/>
                    <TextBlock Text="{Binding RejectedCount}" FontSize="28" FontWeight="Bold" 
                               Foreground="#F44336" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- ═════════ SEARCH & FILTER BAR ═════════ -->
        <Border Grid.Row="2" Background="{DynamicResource CardBrush}" CornerRadius="8" 
                Padding="16,12" Margin="0,0,0,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox Grid.Column="0" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="36" Padding="12,8" FontSize="13"
                         VerticalContentAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush AlignmentX="Left" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="  🔍  Proje adı, müşteri adı veya proje kodu ara..." 
                                                               Foreground="#9E9E9E" FontSize="13"
                                                               Margin="8,0,0,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="16,0,8,0"
                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}">
                    <Run Text="Filtre:"/>
                    <Run Text="{Binding StatusFilterDisplay, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>
                
                <Button Grid.Column="2" Content="🔄 Yenile" Command="{Binding RefreshCommand}"
                        Padding="12,6" FontSize="12" BorderThickness="1" Cursor="Hand"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═════════ DATA GRID ═════════ -->
        <Border Grid.Row="3" Background="{DynamicResource CardBrush}" CornerRadius="8"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <DataGrid ItemsSource="{Binding QuotesView}"
                      SelectedItem="{Binding SelectedQuote}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      BorderThickness="0"
                      FontSize="13"
                      RowHeight="44">

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="✏️ Düzenle" Command="{Binding EditQuoteCommand}"/>
                        <MenuItem Header="📑 Kopyala" Command="{Binding DuplicateQuoteCommand}"/>
                        <MenuItem Header="📝 PDF Dışa Aktar" Command="{Binding ExportPdfCommand}"/>
                        <Separator/>
                        <MenuItem Header="📨 Gönderildi Olarak İşaretle" Command="{Binding MarkAsSentCommand}"/>
                        <MenuItem Header="✅ Onaylandı Olarak İşaretle" Command="{Binding MarkAsApprovedCommand}"/>
                        <MenuItem Header="❌ Reddedildi Olarak İşaretle" Command="{Binding MarkAsRejectedCommand}"/>
                        <Separator/>
                        <MenuItem Header="🗑️ Sil" Command="{Binding DeleteQuoteCommand}" Foreground="Red"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditQuoteCommand}"/>
                </DataGrid.InputBindings>

                <DataGrid.Columns>
                    <!-- Proje Kodu -->
                    <DataGridTextColumn Header="Proje Kodu" Binding="{Binding ProjectCode}" Width="120">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>

                    <!-- Başlık -->
                    <DataGridTextColumn Header="Proje Adı" Binding="{Binding Title}" Width="*"/>

                    <!-- Müşteri -->
                    <DataGridTextColumn Header="Müşteri" Binding="{Binding Customer.FullName}" Width="160"/>

                    <!-- Tutar -->
                    <DataGridTextColumn Header="Tutar" Binding="{Binding TotalBudget, StringFormat='₺{0:N0}'}" Width="110">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>

                    <!-- Kar -->
                    <DataGridTextColumn Header="Kar" Binding="{Binding TotalProfit, StringFormat='₺{0:N0}'}" Width="100">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" Value="#4CAF50"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>

                    <!-- Durum Badge -->
                    <DataGridTemplateColumn Header="Durum" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding QuoteStatus, Converter={StaticResource StatusColorConverter}}" 
                                        CornerRadius="10" Padding="10,4" HorizontalAlignment="Center"
                                        Margin="4,6">
                                    <TextBlock Text="{Binding QuoteStatus, Converter={StaticResource StatusTextConverter}}" 
                                               Foreground="White" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Revizyon -->
                    <DataGridTextColumn Header="Rev." Binding="{Binding RevisionNumber, StringFormat='R{0}'}" Width="55">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#9C27B0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>

                    <!-- Tarih -->
                    <DataGridTextColumn Header="Oluşturma" Binding="{Binding CreatedDate, Converter={StaticResource DateConverter}}" Width="95"/>

                    <!-- İskonto -->
                    <DataGridTextColumn Header="İskonto" Binding="{Binding DiscountPercent, StringFormat='%{0:N0}'}" Width="70">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" Value="#FF9800"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ═════════ FOOTER ═════════ -->
        <Border Grid.Row="4" Background="{DynamicResource CardBrush}" CornerRadius="8" 
                Padding="16,10" Margin="0,12,0,0"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Durum Mesajı -->
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="12" 
                           Foreground="{DynamicResource SecondaryTextBrush}" 
                           VerticalAlignment="Center"/>

                <!-- Aksiyon Butonları -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="✏️ Düzenle" Command="{Binding EditQuoteCommand}"
                            Margin="0,0,8,0" Padding="14,8" FontSize="12" 
                            BorderThickness="1" Cursor="Hand"/>

                    <Button Content="📝 PDF" Command="{Binding ExportPdfCommand}"
                            Background="#FF9800" Foreground="White"
                            Margin="0,0,8,0" Padding="14,8" FontSize="12" 
                            BorderThickness="0" Cursor="Hand"/>

                    <Button Content="📑 Kopyala" Command="{Binding DuplicateQuoteCommand}"
                            Margin="0,0,8,0" Padding="14,8" FontSize="12" 
                            BorderThickness="1" Cursor="Hand"/>

                    <Button Content="🗑️ Sil" Command="{Binding DeleteQuoteCommand}"
                            Background="#F44336" Foreground="White"
                            Padding="14,8" FontSize="12" 
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
