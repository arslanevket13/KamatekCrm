<UserControl x:Class="KamatekCrm.Views.StockCountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:KamatekCrm.Views"
             xmlns:viewmodels="clr-namespace:KamatekCrm.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="{DynamicResource SurfacePageBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.DataContext>
        <viewmodels:StockCountViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- TabControl -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="📦" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Fiziksel Stok Sayımı" 
                           FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextHeadingBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- History Button -->
            <Button Grid.Column="1" 
                    Content="📋 Geçmiş" 
                    Command="{Binding ShowHistoryCommand}"
                    Style="{StaticResource SecondaryButton}"
                    Height="35" Width="100"/>
        </Grid>

        <!-- TabControl -->
        <TabControl Grid.Row="1">
            
            <!-- ============================================= -->
            <!-- TAB 1: Excel Toplu Sayım (Mevcut İşlevsellik) -->
            <!-- ============================================= -->
            <TabItem Header="📤 Excel Toplu Sayım">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Filters -->
                        <RowDefinition Height="*"/>    <!-- DataGrid -->
                        <RowDefinition Height="Auto"/> <!-- Summary -->
                        <RowDefinition Height="Auto"/> <!-- Footer -->
                    </Grid.RowDefinitions>

                    <!-- Filters -->
                    <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="15" Margin="0,10,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Warehouse Selection -->
                            <StackPanel Grid.Column="0">
                                <Label Content="Sayım Yapılacak Depo" Style="{StaticResource ModernLabel}"/>
                                <ComboBox ItemsSource="{Binding Warehouses}"
                                          SelectedItem="{Binding SelectedWarehouse}"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <!-- Search Box -->
                            <StackPanel Grid.Column="2">
                                <Label Content="Ürün Ara (Kod/Ad)" Style="{StaticResource ModernLabel}"/>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"
                                         VerticalContentAlignment="Center">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Escape" Command="{Binding RefreshCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                            </StackPanel>

                            <!-- Count Date -->
                            <StackPanel Grid.Column="4" Width="150">
                                <Label Content="Sayım Tarihi" Style="{StaticResource ModernLabel}"/>
                                <DatePicker SelectedDate="{Binding CountDate}"
                                            Style="{x:Null}"/>
                            </StackPanel>

                            <!-- Refresh Button -->
                            <Button Grid.Column="6" Content="🔄" 
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    ToolTip="Listeyi Yenile"
                                    VerticalAlignment="Bottom" Height="35" Width="40"/>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <Border Grid.Row="1" Style="{StaticResource CardPanel}" Padding="0">
                        <DataGrid ItemsSource="{Binding CountItemsView}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                  RowHeight="40"
                                  ColumnHeaderHeight="45">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextHeadingBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource StatusInfoBg}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextHeadingBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <!-- Product Code -->
                                <DataGridTextColumn Header="Ürün Kodu" 
                                                    Binding="{Binding ProductCode}" 
                                                    Width="120" 
                                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="12,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Product Name -->
                                <DataGridTextColumn Header="Ürün Adı" 
                                                    Binding="{Binding ProductName}" 
                                                    Width="*" 
                                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="12,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Unit -->
                                <DataGridTextColumn Header="Birim" 
                                                    Binding="{Binding Unit}" 
                                                    Width="70" 
                                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- System Quantity (ReadOnly) -->
                                <DataGridTextColumn Header="Sistem Miktar" 
                                                    Binding="{Binding SystemQuantity}" 
                                                    Width="110" 
                                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Counted Quantity (Editable) -->
                                <DataGridTextColumn Header="Sayılan Miktar" 
                                                    Binding="{Binding CountedQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                                    Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ThemePrimary}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Background" Value="{DynamicResource StatusWarningBgLight}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="Background" Value="{DynamicResource StatusWarningBg}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource ThemeWarning}"/>
                                            <Setter Property="Padding" Value="5,3"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>

                                <!-- Difference (Color-coded) -->
                                <DataGridTemplateColumn Header="Fark" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Difference, Converter={x:Static local:IsPositiveConverter.Instance}}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource StatusSuccessBg}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Difference, Converter={x:Static local:IsNegativeConverter.Instance}}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource StatusErrorBg}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Difference, StringFormat='{}{0:+#;-#;0}'}" 
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Difference, Converter={x:Static local:IsPositiveConverter.Instance}}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource StatusSuccessFg}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Difference, Converter={x:Static local:IsNegativeConverter.Instance}}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource StatusErrorFg}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Summary Cards -->
                    <Grid Grid.Row="2" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Total Items -->
                        <Border Grid.Column="0" Background="{DynamicResource StatusWarningBg}" CornerRadius="8" Padding="15" Margin="0,0,7,0">
                            <StackPanel>
                                <TextBlock Text="Toplam Ürün" Foreground="{DynamicResource StatusWarningFg}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding TotalItemCount, StringFormat='{}{0} kalem'}" 
                                           FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusWarningFgDark}"/>
                            </StackPanel>
                        </Border>

                        <!-- Positive Difference -->
                        <Border Grid.Column="1" Background="{DynamicResource StatusSuccessBg}" CornerRadius="8" Padding="15" Margin="7,0,7,0">
                            <StackPanel>
                                <TextBlock Text="Sayım Fazlası" Foreground="{DynamicResource StatusSuccessFgDark}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding TotalPositiveDifference, StringFormat='+{0} adet'}" 
                                           FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusSuccessFg}"/>
                            </StackPanel>
                        </Border>

                        <!-- Negative Difference -->
                        <Border Grid.Column="2" Background="{DynamicResource StatusErrorBg}" CornerRadius="8" Padding="15" Margin="7,0,7,0">
                            <StackPanel>
                                <TextBlock Text="Sayım Eksiği" Foreground="{DynamicResource StatusErrorFgDark}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding TotalNegativeDifference, StringFormat='{}{0} adet'}" 
                                           FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusErrorFg}"/>
                            </StackPanel>
                        </Border>

                        <!-- Items with Difference -->
                        <Border Grid.Column="3" Background="{DynamicResource StatusInfoBgLight}" CornerRadius="8" Padding="15" Margin="7,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Farklı Ürün" Foreground="{DynamicResource StatusInfoFg}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding TotalDifferenceCount, StringFormat='{}{0} kalem'}" 
                                           FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusInfoFgDark}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Footer -->
                    <Grid Grid.Row="3" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status Message -->
                        <TextBlock Grid.Column="0" 
                                   Text="{Binding StatusMessage}" 
                                   VerticalAlignment="Center"
                                   FontWeight="Medium">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource StatusErrorFg}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActionSuccessful}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource StatusSuccessFg}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                            <Button Content="📤 Excel'den Aktar" 
                                    Command="{Binding ImportFromExcelCommand}"
                                    Style="{StaticResource SecondaryButton}" 
                                    ToolTip="Excel dosyasından sayım verilerini yükle (Sütun1: Stok Kodu/Model, Sütun2: Miktar)"
                                    Width="140" Height="40" Margin="0,0,10,0"/>
                            <Button Content="📥 Excel'e Aktar" 
                                    Command="{Binding ExportToExcelCommand}"
                                    Style="{StaticResource SecondaryButton}" 
                                    Width="130" Height="40"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="✅ Sayımı Kaydet ve Stoğu Düzelt" 
                                    Command="{Binding SaveCountCommand}"
                                    Style="{StaticResource ModernButton}" 
                                    Width="260" Height="40"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============================================= -->
            <!-- TAB 2: Manuel Hızlı Sayım (YENİ)              -->
            <!-- ============================================= -->
            <TabItem Header="🖐️ Manuel Hızlı Sayım">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Depo + Arama -->
                        <RowDefinition Height="*"/>    <!-- DataGrid -->
                        <RowDefinition Height="Auto"/> <!-- Summary -->
                        <RowDefinition Height="Auto"/> <!-- Footer -->
                    </Grid.RowDefinitions>

                    <!-- Üst Panel: Depo Seçimi ve Ürün Arama -->
                    <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="15" Margin="0,10,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Depo Seçimi -->
                            <StackPanel Grid.Column="0">
                                <Label Content="Sayım Yapılacak Depo" Style="{StaticResource ModernLabel}"/>
                                <ComboBox ItemsSource="{Binding Warehouses}"
                                          SelectedItem="{Binding ManualSelectedWarehouse}"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <!-- Ürün Arama -->
                            <StackPanel Grid.Column="2">
                                <Label Content="Ürün Ara (Ad / SKU / Barkod)" Style="{StaticResource ModernLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              Text="{Binding ManualSearchText, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding ManualSearchResults}"
                                              SelectedItem="{Binding SelectedSearchResult}"
                                              IsEditable="True"
                                              IsTextSearchEnabled="False"
                                              Style="{StaticResource ModernComboBox}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding SKU}" FontWeight="Bold" Width="100"/>
                                                    <TextBlock Text=" - "/>
                                                    <TextBlock Text="{Binding ProductName}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>

                            <!-- Ekle Butonu -->
                            <Button Grid.Column="4" 
                                    Content="➕ Listeye Ekle" 
                                    Command="{Binding AddToManualCountCommand}"
                                    Style="{StaticResource ModernButton}"
                                    VerticalAlignment="Bottom" Height="35" Width="130"/>
                        </Grid>
                    </Border>

                    <!-- Manuel Sayım DataGrid -->
                    <Border Grid.Row="1" Style="{StaticResource CardPanel}" Padding="0">
                        <DataGrid ItemsSource="{Binding ManualCountItems}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                  RowHeight="45"
                                  ColumnHeaderHeight="45">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource StatusInfoBg}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ThemePrimary}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource ThemePrimaryLight}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ThemePrimaryLight}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextHeadingBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <!-- Ürün Kodu -->
                                <DataGridTextColumn Header="Ürün Kodu" 
                                                    Binding="{Binding ProductCode}" 
                                                    Width="120" 
                                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="12,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Ürün Adı -->
                                <DataGridTextColumn Header="Ürün Adı" 
                                                    Binding="{Binding ProductName}" 
                                                    Width="*" 
                                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="12,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Birim -->
                                <DataGridTextColumn Header="Birim" 
                                                    Binding="{Binding Unit}" 
                                                    Width="70" 
                                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Sistem Miktar (ReadOnly) -->
                                <DataGridTextColumn Header="Sistem Stok" 
                                                    Binding="{Binding SystemQuantity}" 
                                                    Width="100" 
                                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Sayılan Miktar (Editable) -->
                                <DataGridTextColumn Header="Sayılan Miktar" 
                                                    Binding="{Binding CountedQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                                    Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ThemePrimary}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="Background" Value="{DynamicResource StatusInfoBg}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource ThemePrimary}"/>
                                            <Setter Property="Padding" Value="5,3"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>

                                <!-- Fark (Color-coded) -->
                                <DataGridTemplateColumn Header="Fark" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Difference, Converter={x:Static local:IsPositiveConverter.Instance}}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource StatusSuccessBg}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Difference, Converter={x:Static local:IsNegativeConverter.Instance}}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource StatusErrorBg}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Difference, StringFormat='{}{0:+#;-#;0}'}" 
                                                           FontWeight="Bold"
                                                           FontSize="13"
                                                           HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Difference, Converter={x:Static local:IsPositiveConverter.Instance}}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource StatusSuccessFg}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Difference, Converter={x:Static local:IsNegativeConverter.Instance}}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource StatusErrorFg}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Sil Butonu -->
                                <DataGridTemplateColumn Header="" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑️" 
                                                    Command="{Binding DataContext.RemoveFromManualCountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Listeden Çıkar"
                                                    FontSize="14"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Manuel Özet Kartları -->
                    <Grid Grid.Row="2" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Toplam Ürün -->
                        <Border Grid.Column="0" Background="{DynamicResource StatusInfoBg}" CornerRadius="8" Padding="15" Margin="0,0,7,0">
                            <StackPanel>
                                <TextBlock Text="Toplam Ürün" Foreground="{DynamicResource StatusInfoFg}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding ManualTotalItemCount, StringFormat='{}{0} kalem'}" 
                                           FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ThemePrimary}"/>
                            </StackPanel>
                        </Border>

                        <!-- Sayım Fazlası -->
                        <Border Grid.Column="1" Background="{DynamicResource StatusSuccessBg}" CornerRadius="8" Padding="15" Margin="7,0,7,0">
                            <StackPanel>
                                <TextBlock Text="Sayım Fazlası" Foreground="{DynamicResource StatusSuccessFgDark}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding ManualTotalPositiveDifference, StringFormat='+{0} adet'}" 
                                           FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusSuccessFg}"/>
                            </StackPanel>
                        </Border>

                        <!-- Sayım Eksiği -->
                        <Border Grid.Column="2" Background="{DynamicResource StatusErrorBg}" CornerRadius="8" Padding="15" Margin="7,0,7,0">
                            <StackPanel>
                                <TextBlock Text="Sayım Eksiği" Foreground="{DynamicResource StatusErrorFgDark}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding ManualTotalNegativeDifference, StringFormat='{}{0} adet'}" 
                                           FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusErrorFg}"/>
                            </StackPanel>
                        </Border>

                        <!-- Farklı Ürün -->
                        <Border Grid.Column="3" Background="{DynamicResource StatusWarningBg}" CornerRadius="8" Padding="15" Margin="7,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Farklı Ürün" Foreground="{DynamicResource StatusWarningFgDark}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding ManualTotalDifferenceCount, StringFormat='{}{0} kalem'}" 
                                           FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusWarningFgDark}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Manuel Sayım Footer -->
                    <Grid Grid.Row="3" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status Message -->
                        <TextBlock Grid.Column="0" 
                                   Text="{Binding StatusMessage}" 
                                   VerticalAlignment="Center"
                                   FontWeight="Medium">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource StatusErrorFg}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActionSuccessful}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource StatusSuccessFg}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Listeyi Temizle -->
                        <Button Grid.Column="1" 
                                Content="🗑️ Listeyi Temizle" 
                                Command="{Binding ClearManualListCommand}"
                                Style="{StaticResource SecondaryButton}" 
                                Width="140" Height="40" Margin="0,0,10,0"/>
                        
                        <!-- Sayımı Onayla -->
                        <Button Grid.Column="2" 
                                Content="✅ Sayımı Onayla ve Stokları Güncelle" 
                                Command="{Binding ConfirmManualCountCommand}"
                                Style="{StaticResource ModernButton}" 
                                Width="280" Height="40"/>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- History Popup Overlay -->
        <Border Grid.RowSpan="2" 
                Background="{DynamicResource CardShadowColor}" 
                Visibility="{Binding IsHistoryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                    CornerRadius="12" 
                    MaxWidth="700" 
                    MaxHeight="500"
                    Margin="50"
                    Padding="20"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="5"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Popup Header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="📋" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Sayım Geçmişi" FontSize="20" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextHeadingBrush}"/>
                    </StackPanel>
                    
                    <!-- History DataGrid -->
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding CountHistory}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource BorderDefaultBrush}"
                              RowHeight="35">
                        
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih" 
                                                Binding="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Depo" 
                                                Binding="{Binding WarehouseName}" 
                                                Width="*"/>
                            <DataGridTextColumn Header="Ürün Sayısı" 
                                                Binding="{Binding ProductCount}" 
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Net Fark" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TotalDifference, StringFormat='{}{0:+#;-#;0}'}" 
                                                   HorizontalAlignment="Center"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TotalDifference, Converter={x:Static local:IsPositiveConverter.Instance}}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource StatusSuccessFg}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TotalDifference, Converter={x:Static local:IsNegativeConverter.Instance}}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource StatusErrorFg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Referans" 
                                                Binding="{Binding ReferenceId}" 
                                                Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Close Button -->
                    <Button Grid.Row="2" 
                            Content="Kapat" 
                            Command="{Binding CloseHistoryCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="100" Height="35"
                            HorizontalAlignment="Right"
                            Margin="0,15,0,0"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>

