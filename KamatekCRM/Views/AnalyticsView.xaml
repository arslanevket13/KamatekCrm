<UserControl x:Class="KamatekCrm.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{DynamicResource SurfacePageBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- KPI Cards -->
            <RowDefinition Height="*"/>    <!-- Charts -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Analitik &amp; Raporlar 📈" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextHeadingBrush}" Margin="0,0,0,20"/>

        <!-- KPI Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1 -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="15" Effect="{DynamicResource DropShadow}">
                <StackPanel>
                    <TextBlock Text="Toplam İşler" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="14"/>
                    <TextBlock Text="{Binding TotalJobs}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ThemePrimary}"/>
                </StackPanel>
            </Border>

            <!-- Card 2 -->
            <Border Grid.Column="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="15" Effect="{DynamicResource DropShadow}">
                <StackPanel>
                    <TextBlock Text="Tamamlanan" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="14"/>
                    <TextBlock Text="{Binding CompletedJobs}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ThemeSuccess}"/>
                </StackPanel>
            </Border>

            <!-- Card 3 -->
            <Border Grid.Column="4" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="15" Effect="{DynamicResource DropShadow}">
                <StackPanel>
                    <TextBlock Text="Başarı Oranı" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="14"/>
                    <TextBlock Text="{Binding SuccessRate, StringFormat={}{0:N1}%}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Charts Grid -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/> <!-- Pie -->
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="1.5*"/> <!-- Bar/Line -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 1. Pie Chart: İş Türü Dağılımı -->
            <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="15" Effect="{DynamicResource DropShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Arıza Türü Dağılımı" FontWeight="Bold" Foreground="{DynamicResource TextHeadingBrush}" Margin="0,0,0,10"/>
                    <lvc:PieChart Grid.Row="1" Series="{Binding JobDistributionSeries}" LegendPosition="Right"/>
                </Grid>
            </Border>

            <!-- 2. Column Chart: Teknisyen Performansı -->
            <Border Grid.Column="2" Grid.Row="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="15" Effect="{DynamicResource DropShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="En İyi Teknisyenler (Top 5)" FontWeight="Bold" Foreground="{DynamicResource TextHeadingBrush}" Margin="0,0,0,10"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding TechPerformanceSeries}" XAxes="{Binding TechXAxes}"/>
                </Grid>
            </Border>

            <!-- 3. Line Chart: Aylık Trend -->
            <Border Grid.Column="2" Grid.Row="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="15" Effect="{DynamicResource DropShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Son 6 Ay İş Trendi" FontWeight="Bold" Foreground="{DynamicResource TextHeadingBrush}" Margin="0,0,0,10"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding TrendSeries}" XAxes="{Binding TrendXAxes}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

